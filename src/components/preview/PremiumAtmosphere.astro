---
interface Props {
  variant?: 'hero' | 'contact';
}

const { variant = 'hero' } = Astro.props;
---

<div class:list={['blueprint-sketch', `blueprint-sketch--${variant}`]} aria-hidden="true">
  <div class="blueprint-sketch__cluster blueprint-sketch__cluster--left">
    <svg class="blueprint-sketch__svg" viewBox="0 0 520 720" preserveAspectRatio="xMinYMid slice">
      <g class="blueprint-sketch__layer blueprint-sketch__layer--mesh">
        <polygon points="20,480 195,240 340,420" />
        <polygon points="95,175 270,85 355,265" />
        <polygon points="185,395 385,310 295,545" />
        <polygon points="35,320 165,195 255,355" />
        <polygon points="265,485 445,365 355,595" />
        <polygon points="125,525 285,420 210,640" />
        <polygon points="310,210 420,155 475,290" />
      </g>

      <g class="blueprint-sketch__layer blueprint-sketch__layer--grid">
        <path d="M40 370 195 255 300 335 430 195" />
        <path d="M75 515 245 405 370 460 495 335" />
        <path d="M110 195 245 130 330 230 460 165" />
        <path d="M195 330 320 255 405 385" />
        <path d="M28 430 155 340" />
        <path d="M300 285 430 240" />
        <path d="M95 580 265 475 395 520" />
        <path d="M355 195 445 250 410 340" />
      </g>

      <g class="blueprint-sketch__layer blueprint-sketch__layer--nodes">
        <circle cx="40" cy="370" r="4.5" class="blueprint-sketch__node blueprint-sketch__node--1" />
        <circle cx="195" cy="255" r="4" class="blueprint-sketch__node blueprint-sketch__node--2" />
        <circle cx="300" cy="335" r="4.5" class="blueprint-sketch__node blueprint-sketch__node--3" />
        <circle cx="430" cy="195" r="4" class="blueprint-sketch__node blueprint-sketch__node--4" />
        <circle cx="95" cy="175" r="3.75" class="blueprint-sketch__node blueprint-sketch__node--5" />
        <circle cx="270" cy="85" r="4" class="blueprint-sketch__node blueprint-sketch__node--6" />
        <circle cx="340" cy="420" r="4.25" class="blueprint-sketch__node blueprint-sketch__node--7" />
        <circle cx="185" cy="395" r="3.5" class="blueprint-sketch__node blueprint-sketch__node--8" />
        <circle cx="445" cy="365" r="4" class="blueprint-sketch__node blueprint-sketch__node--9" />
        <circle cx="265" cy="485" r="3.75" class="blueprint-sketch__node blueprint-sketch__node--10" />
        <circle cx="125" cy="525" r="3.5" class="blueprint-sketch__node blueprint-sketch__node--11" />
        <circle cx="355" cy="265" r="4" class="blueprint-sketch__node blueprint-sketch__node--12" />
      </g>
    </svg>
  </div>

  <div class="blueprint-sketch__cluster blueprint-sketch__cluster--right">
    <svg class="blueprint-sketch__svg" viewBox="0 0 520 720" preserveAspectRatio="xMaxYMid slice">
      <g class="blueprint-sketch__layer blueprint-sketch__layer--mesh">
        <polygon points="20,480 195,240 340,420" />
        <polygon points="95,175 270,85 355,265" />
        <polygon points="185,395 385,310 295,545" />
        <polygon points="35,320 165,195 255,355" />
        <polygon points="265,485 445,365 355,595" />
        <polygon points="125,525 285,420 210,640" />
        <polygon points="310,210 420,155 475,290" />
      </g>

      <g class="blueprint-sketch__layer blueprint-sketch__layer--grid">
        <path d="M40 370 195 255 300 335 430 195" />
        <path d="M75 515 245 405 370 460 495 335" />
        <path d="M110 195 245 130 330 230 460 165" />
        <path d="M195 330 320 255 405 385" />
        <path d="M28 430 155 340" />
        <path d="M300 285 430 240" />
        <path d="M95 580 265 475 395 520" />
        <path d="M355 195 445 250 410 340" />
      </g>

      <g class="blueprint-sketch__layer blueprint-sketch__layer--nodes">
        <circle cx="40" cy="370" r="4.5" class="blueprint-sketch__node blueprint-sketch__node--13" />
        <circle cx="195" cy="255" r="4" class="blueprint-sketch__node blueprint-sketch__node--14" />
        <circle cx="300" cy="335" r="4.5" class="blueprint-sketch__node blueprint-sketch__node--15" />
        <circle cx="430" cy="195" r="4" class="blueprint-sketch__node blueprint-sketch__node--16" />
        <circle cx="95" cy="175" r="3.75" class="blueprint-sketch__node blueprint-sketch__node--17" />
        <circle cx="270" cy="85" r="4" class="blueprint-sketch__node blueprint-sketch__node--18" />
        <circle cx="340" cy="420" r="4.25" class="blueprint-sketch__node blueprint-sketch__node--19" />
        <circle cx="185" cy="395" r="3.5" class="blueprint-sketch__node blueprint-sketch__node--20" />
        <circle cx="445" cy="365" r="4" class="blueprint-sketch__node blueprint-sketch__node--21" />
        <circle cx="265" cy="485" r="3.75" class="blueprint-sketch__node blueprint-sketch__node--22" />
        <circle cx="125" cy="525" r="3.5" class="blueprint-sketch__node blueprint-sketch__node--23" />
        <circle cx="355" cy="265" r="4" class="blueprint-sketch__node blueprint-sketch__node--24" />
      </g>
    </svg>
  </div>
</div>

<style>
  .blueprint-sketch {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    color: rgba(255, 255, 255, 0.9);
    opacity: 0.15;
  }

  .blueprint-sketch__cluster {
    position: absolute;
    top: -10%;
    width: min(58vw, 34rem);
    height: 120%;
    will-change: transform;
  }

  .blueprint-sketch__cluster--left {
    left: -14%;
    animation: blueprint-drift-left 17s ease-in-out infinite;
  }

  .blueprint-sketch__cluster--right {
    right: -14%;
    animation: blueprint-drift-right 19s ease-in-out infinite 2.4s;
  }

  .blueprint-sketch__cluster--right .blueprint-sketch__svg {
    transform: scaleX(-1);
  }

  .blueprint-sketch__svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .blueprint-sketch__layer polygon,
  .blueprint-sketch__layer path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.05;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .blueprint-sketch__layer--mesh {
    animation: blueprint-layer-breathe 11s ease-in-out infinite;
  }

  .blueprint-sketch__layer--grid {
    stroke-width: 1.15;
    animation: blueprint-layer-breathe 8.5s ease-in-out infinite 1.8s;
  }

  .blueprint-sketch__layer--nodes {
    animation: blueprint-layer-breathe 9.5s ease-in-out infinite 0.9s;
  }

  .blueprint-sketch__node {
    fill: rgba(255, 255, 255, 0.25);
    stroke: currentColor;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .blueprint-sketch__node--1 { animation: blueprint-node-pulse 6.2s ease-in-out infinite; }
  .blueprint-sketch__node--2 { animation: blueprint-node-pulse 7.4s ease-in-out infinite 0.7s; }
  .blueprint-sketch__node--3 { animation: blueprint-node-pulse 5.8s ease-in-out infinite 1.4s; }
  .blueprint-sketch__node--4 { animation: blueprint-node-pulse 8.1s ease-in-out infinite 2.1s; }
  .blueprint-sketch__node--5 { animation: blueprint-node-pulse 6.8s ease-in-out infinite 0.4s; }
  .blueprint-sketch__node--6 { animation: blueprint-node-pulse 7.9s ease-in-out infinite 1.9s; }
  .blueprint-sketch__node--7 { animation: blueprint-node-pulse 6.4s ease-in-out infinite 2.8s; }
  .blueprint-sketch__node--8 { animation: blueprint-node-pulse 8.4s ease-in-out infinite 1.1s; }
  .blueprint-sketch__node--9 { animation: blueprint-node-pulse 7.1s ease-in-out infinite 3.2s; }
  .blueprint-sketch__node--10 { animation: blueprint-node-pulse 6.6s ease-in-out infinite 0.2s; }
  .blueprint-sketch__node--11 { animation: blueprint-node-pulse 9.2s ease-in-out infinite 1.6s; }
  .blueprint-sketch__node--12 { animation: blueprint-node-pulse 8.8s ease-in-out infinite 2.4s; }
  .blueprint-sketch__node--13 { animation: blueprint-node-pulse 6.9s ease-in-out infinite 0.5s; }
  .blueprint-sketch__node--14 { animation: blueprint-node-pulse 7.6s ease-in-out infinite 1.3s; }
  .blueprint-sketch__node--15 { animation: blueprint-node-pulse 6.1s ease-in-out infinite 2.2s; }
  .blueprint-sketch__node--16 { animation: blueprint-node-pulse 8.3s ease-in-out infinite 0.9s; }
  .blueprint-sketch__node--17 { animation: blueprint-node-pulse 7.2s ease-in-out infinite 3.1s; }
  .blueprint-sketch__node--18 { animation: blueprint-node-pulse 6.5s ease-in-out infinite 1.8s; }
  .blueprint-sketch__node--19 { animation: blueprint-node-pulse 8.6s ease-in-out infinite 2.6s; }
  .blueprint-sketch__node--20 { animation: blueprint-node-pulse 5.9s ease-in-out infinite 0.6s; }
  .blueprint-sketch__node--21 { animation: blueprint-node-pulse 7.8s ease-in-out infinite 1.5s; }
  .blueprint-sketch__node--22 { animation: blueprint-node-pulse 6.3s ease-in-out infinite 2.9s; }
  .blueprint-sketch__node--23 { animation: blueprint-node-pulse 9s ease-in-out infinite 0.3s; }
  .blueprint-sketch__node--24 { animation: blueprint-node-pulse 8.2s ease-in-out infinite 2s; }

  .blueprint-sketch--contact .blueprint-sketch__cluster--left {
    animation-duration: 20s;
    animation-delay: 1.2s;
  }

  .blueprint-sketch--contact .blueprint-sketch__cluster--right {
    animation-duration: 18s;
    animation-delay: 3.6s;
  }

  @keyframes blueprint-drift-left {
    0%,
    100% {
      transform: translate(0, 0);
    }

    50% {
      transform: translate(10px, -8px);
    }
  }

  @keyframes blueprint-drift-right {
    0%,
    100% {
      transform: translate(0, 0);
    }

    50% {
      transform: translate(-10px, 6px);
    }
  }

  @keyframes blueprint-layer-breathe {
    0%,
    100% {
      opacity: 0.5;
    }

    50% {
      opacity: 0.92;
    }
  }

  @keyframes blueprint-node-pulse {
    0%,
    100% {
      opacity: 0.3;
      fill: rgba(255, 255, 255, 0.15);
    }

    50% {
      opacity: 1;
      fill: rgba(255, 255, 255, 0.65);
    }
  }

  @media (max-width: 767px) {
    .blueprint-sketch {
      opacity: 0.11;
    }

    .blueprint-sketch__cluster {
      width: min(72vw, 22rem);
      top: -6%;
      height: 112%;
      will-change: auto;
      animation: none;
    }

    .blueprint-sketch__layer,
    .blueprint-sketch__node {
      animation: none;
    }

    .blueprint-sketch__cluster--left {
      left: -22%;
    }

    .blueprint-sketch__cluster--right {
      right: -22%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blueprint-sketch__cluster,
    .blueprint-sketch__layer,
    .blueprint-sketch__node {
      animation: none;
      opacity: 1;
    }
  }
</style>
