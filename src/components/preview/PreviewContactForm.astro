---
import CheckIcon from '../icons/CheckIcon.astro';
import Reveal from '../Reveal.astro';
import PremiumAtmosphere from './PremiumAtmosphere.astro';
import { homeCta, formPlaceholders, formLabels } from '../../data/site';
---

<section id="contact" class="preview-contact-depth contact-section section-padding below-fold relative overflow-hidden">
  <PremiumAtmosphere variant="contact" />

  <div class="relative mx-auto max-w-6xl px-4 md:px-6">
    <Reveal>
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16 xl:gap-20">
        <div class="order-2 flex flex-col justify-center text-right text-white max-lg:items-center max-lg:text-center lg:order-none lg:min-h-[28rem]">
          <blockquote class="mb-8 max-w-md text-lg font-bold leading-relaxed text-white/95 md:text-xl">
            "ירדנו ב-46% בעלות לליד בזכות טירגוט חכם ושיפור מתמיד בקמפיינים."
            <footer class="mt-3 text-base font-semibold text-white/75">עמית שניידר, SKI VIP Travel</footer>
          </blockquote>

          <ul class="contact-benefits space-y-5 text-lg text-white/90 md:text-xl lg:space-y-6" aria-label="יתרונות">
            <li class="flex items-center justify-start gap-3.5 max-lg:justify-center">
              <span class="contact-check" aria-hidden="true"><CheckIcon /></span>
              <span>בדיקת הפרסום הנוכחי שלך</span>
            </li>
            <li class="flex items-center justify-start gap-3.5 max-lg:justify-center">
              <span class="contact-check" aria-hidden="true"><CheckIcon /></span>
              <span>המלצות מעשיות לשיפור</span>
            </li>
            <li class="flex items-center justify-start gap-3.5 max-lg:justify-center">
              <span class="contact-check" aria-hidden="true"><CheckIcon /></span>
              <span>מענה תוך 24 שעות</span>
            </li>
          </ul>
        </div>

        <div class="order-1 w-full max-w-lg justify-self-start lg:order-none lg:max-w-none">
          <div class="contact-form-heading mb-8 w-full text-right text-white md:mb-10">
            <p class="contact-form-eyebrow mb-3 font-semibold text-white/85">ללא כל התחייבות</p>
            <h2 class="contact-form-title w-full font-black leading-tight">השאר פרטים וקבל אבחון חינם</h2>
          </div>

          <form
            class="contact-form w-full"
            method="POST"
            action="#"
            id="preview-contact-form"
            novalidate
            autocomplete="off"
          >
            <div class="space-y-3.5">
              <div class="field-group">
                <label for="preview-name" class="preview-contact-label">{formLabels.name}</label>
                <input
                  type="text"
                  id="preview-name"
                  name="name"
                  required
                  autocomplete="name"
                  class="contact-input"
                  placeholder={formPlaceholders.name}
                  aria-describedby="preview-name-error"
                />
                <p id="preview-name-error" class="field-error hidden" role="alert"></p>
              </div>

              <div class="field-group">
                <label for="preview-phone" class="preview-contact-label">{formLabels.phone}</label>
                <input
                  type="tel"
                  id="preview-phone"
                  name="phone"
                  required
                  inputmode="tel"
                  autocomplete="tel"
                  pattern="[0-9\-+() ]{9,15}"
                  class="contact-input"
                  placeholder={formPlaceholders.phone}
                  aria-describedby="preview-phone-error"
                />
                <p id="preview-phone-error" class="field-error hidden" role="alert"></p>
              </div>

              <div class="field-group">
                <label for="preview-vertical" class="preview-contact-label">{formLabels.vertical}</label>
                <input
                  type="text"
                  id="preview-vertical"
                  name="vertical"
                  required
                  autocomplete="organization-title"
                  class="contact-input"
                  placeholder={formPlaceholders.vertical}
                  aria-describedby="preview-vertical-error"
                />
                <p id="preview-vertical-error" class="field-error hidden" role="alert"></p>
              </div>
            </div>

            <label class="contact-privacy mt-5 flex cursor-pointer items-start gap-3">
              <input
                type="checkbox"
                id="preview-privacy"
                name="privacy"
                required
                class="contact-checkbox mt-0.5 shrink-0"
                aria-describedby="preview-privacy-error"
              />
              <span class="text-right text-sm leading-relaxed text-white/75">
                קראתי ואני מאשר/ת את{' '}
                <a href="/prat" class="text-brand-yellow underline underline-offset-2 hover:text-white"
                  >מדיניות הפרטיות</a>, ומסכים/ה לשמירת המידע לצורך טיפול בפנייתי (חובה)
              </span>
            </label>
            <p id="preview-privacy-error" class="field-error mt-2 hidden text-right" role="alert"></p>

            <button type="submit" id="preview-contact-submit" class="btn-yellow contact-submit mt-6 w-full rounded-full">
              <span id="preview-contact-submit-label">{homeCta}</span>
            </button>

            <p
              id="preview-form-status"
              class="form-success mt-4 hidden text-center text-sm font-semibold"
              role="status"
              aria-live="polite"
            ></p>
          </form>
        </div>
      </div>
    </Reveal>
  </div>
</section>

<script>
  const form = document.getElementById('preview-contact-form') as HTMLFormElement | null;
  const status = document.getElementById('preview-form-status');
  const submitBtn = document.getElementById('preview-contact-submit') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('preview-contact-submit-label');

  const fields = {
    name: {
      input: document.getElementById('preview-name') as HTMLInputElement | null,
      error: document.getElementById('preview-name-error'),
      message: 'נא להזין שם מלא',
    },
    phone: {
      input: document.getElementById('preview-phone') as HTMLInputElement | null,
      error: document.getElementById('preview-phone-error'),
      message: 'נא להזין מספר טלפון תקין',
    },
    vertical: {
      input: document.getElementById('preview-vertical') as HTMLInputElement | null,
      error: document.getElementById('preview-vertical-error'),
      message: 'נא להזין את תחום העסק',
    },
    privacy: {
      input: document.getElementById('preview-privacy') as HTMLInputElement | null,
      error: document.getElementById('preview-privacy-error'),
      message: 'יש לאשר את מדיניות הפרטיות',
    },
  };

  const setFieldError = (key: keyof typeof fields, show: boolean) => {
    const field = fields[key];
    if (!field.input || !field.error) return;
    field.input.classList.toggle('contact-input--error', show);
    field.input.setAttribute('aria-invalid', show ? 'true' : 'false');
    field.error.textContent = show ? field.message : '';
    field.error.classList.toggle('hidden', !show);
  };

  const validate = () => {
    let valid = true;
    if (!fields.name.input?.value.trim()) {
      setFieldError('name', true);
      valid = false;
    } else setFieldError('name', false);

    const phone = fields.phone.input?.value.trim() ?? '';
    if (!phone || !/^[0-9\-+() ]{9,15}$/.test(phone)) {
      setFieldError('phone', true);
      valid = false;
    } else setFieldError('phone', false);

    if (!fields.vertical.input?.value.trim()) {
      setFieldError('vertical', true);
      valid = false;
    } else setFieldError('vertical', false);

    if (!fields.privacy.input?.checked) {
      setFieldError('privacy', true);
      valid = false;
    } else setFieldError('privacy', false);

    return valid;
  };

  Object.values(fields).forEach((field) => {
    field.input?.addEventListener('blur', validate);
    field.input?.addEventListener('input', () => {
      if (field.input?.getAttribute('aria-invalid') === 'true') validate();
    });
    field.input?.addEventListener('change', () => {
      if (field.input?.getAttribute('aria-invalid') === 'true') validate();
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status?.classList.add('hidden');
    if (!validate()) {
      const firstInvalid = form.querySelector<HTMLElement>('[aria-invalid="true"]');
      firstInvalid?.focus();
      return;
    }

    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'שולח…';

    const payload = {
      name: fields.name.input?.value.trim(),
      phone: fields.phone.input?.value.trim(),
      email: '',
      vertical: fields.vertical.input?.value.trim() || '',
      verticalLabel: fields.vertical.input?.value.trim() || '',
      pageUrl: window.location.href,
      source: 'homepage-contact-form',
      referrer: document.referrer || '',
      language: navigator.language || '',
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = (await res.json()) as { ok?: boolean };
      if (!res.ok || !data.ok) throw new Error('submit failed');
      window.location.href = '/thank-you';
    } catch {
      if (status) {
        status.textContent = 'שגיאה בשליחה. נסו שוב או כתבו ל-info@profitmedia.co.il';
        status.classList.remove('hidden');
        status.setAttribute('role', 'alert');
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = 'קבלו אבחון חינם';
    }
  });
</script>

<style>
  .contact-form-title {
    font-size: clamp(1.375rem, 4.6vw, 2.625rem);
  }

</style>
