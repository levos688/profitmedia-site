---
import LandingLayout from '../../layouts/LandingLayout.astro';

interface Props {
  basePath?: string;
}

const { basePath = '/donhin' } = Astro.props;

const benefits = [
  {
    icon: '/images/donhin/icon-consult.png',
    title: 'Бесплатная консультация',
    text: 'Оценка перспектив дела и помощь в сборе документов.',
  },
  {
    icon: '/images/donhin/icon-payment.png',
    title: 'Оплата по результатам — без риска',
    text: 'Платите только за результат, в котором вы уверены.',
  },
  {
    icon: '/images/donhin/icon-compensation.png',
    title: 'Максимальная компенсация',
    text: 'Компенсация, которая покроет все расходы и моральную компенсацию.',
  },
  {
    icon: '/images/donhin/icon-negotiation.png',
    title: 'Ведение переговоров',
    text: 'Переговоры с врачом, больницей и страховой компанией.',
  },
];

const cases = [
  {
    title: 'Компенсация в размере 115 000 шекелей за неудачное восстановление зубов',
    text: 'Женщина проходила стоматологическое лечение у двух врачей последовательно. Однако оба специалиста лишь ухудшили её состояние, и после многочисленных попыток восстановительное лечение полностью провалилось. В рамках судебного иска стороны пришли к соглашению, согласно которому женщина получит компенсацию в размере 115 000 шекелей.',
  },
  {
    title: 'Компенсация 233 тыс шекелей',
    text: 'Мужчина 50 лет обратился к врачу за стоматологическим протезированием. Изготовленные врачом съемные протезы не подошли пациенту. Врач предложил установить имплантаты и на них сделать постоянный протез. Врач имплантировал пациенту 12 имплантатов, но постоянный протез также не подошел. После многочисленных попыток исправить ситуацию, пациент подал в суд на врача. Суд вынес решение в пользу пациента и присудил ему компенсацию в размере 233 000 шекелей.',
  },
];
const quizFormTitle = 'Ответьте на вопрос — получите бесплатную консультацию адвоката';
---

<LandingLayout
  title="Медицинская халатность в стоматологии | Адвокат Саймон Донхин"
  description="Получите положенную вам компенсацию за халатность стоматолога. Бесплатная консультация адвоката Саймона Донхина."
>
  <main id="main-content" data-donhin-base-path={basePath}>
    <section class="donhin-hero">
      <div class="donhin-container donhin-hero__grid">
        <div class="donhin-hero__content">
          <p class="donhin-eyebrow">Медицинская халатность</p>
          <h1 class="donhin-hero__title">
            Получите положенную вам компенсацию за халатность стоматолога
          </h1>
          <p class="donhin-hero__subtitle">
            За последние 15 лет мои клиенты получили более 20 миллионов шекелей
          </p>
          <a href="#form-quiz" class="donhin-btn donhin-btn--hero">Запишитесь на бесплатную консультацию</a>
        </div>
        <div class="donhin-hero__photo-wrap">
          <img
            src="/images/donhin/hero.webp"
            alt="Адвокат Саймон Донхин"
            class="donhin-hero__photo"
            width="397"
            height="397"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <p class="donhin-hero__name">
            <img
              src="/images/donhin/icon-scales.svg"
              alt=""
              width="47"
              height="33"
              class="donhin-hero__scales"
              loading="lazy"
              decoding="async"
            />
            <span>Адвокат Саймон Донхин</span>
          </p>
        </div>
      </div>
    </section>

    <section class="donhin-benefits">
      <div class="donhin-container">
        <h2 class="donhin-section-title">Почему стоит обратиться к адвокату Саймону?</h2>
        <div class="donhin-benefits__grid">
          {
            benefits.map((item) => (
              <article class="donhin-benefit">
                <div class="donhin-benefit__icon-wrap">
                  <img src={item.icon} alt="" width="150" height="150" class="donhin-benefit__icon" loading="lazy" decoding="async" />
                </div>
                <h3 class="donhin-benefit__title">{item.title}</h3>
                <p class="donhin-benefit__text">{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="form-quiz" class="donhin-form-section">
      <div class="donhin-container donhin-form-section__inner">
        <h2 class="donhin-form-section__title">{quizFormTitle}</h2>

        <form class="donhin-form donhin-form--quiz" id="donhin-quiz-form" data-donhin-form="quiz" novalidate>
          <div class="donhin-form__viewport">
          <div class="donhin-form__step is-active" data-step="1">
            <fieldset class="donhin-quiz">
              <legend class="donhin-quiz__question">
                Оказывалась ли вам медицинская или стоматологическая помощь в последние 7 лет?
              </legend>
              <div class="donhin-quiz__options">
                <label class="donhin-radio">
                  <input type="radio" name="quiz" value="да" required />
                  <span>Да</span>
                </label>
                <label class="donhin-radio">
                  <input type="radio" name="quiz" value="нет" />
                  <span>Нет</span>
                </label>
              </div>
            </fieldset>
            <button type="button" class="donhin-btn donhin-btn--quiz-action" data-quiz-next disabled>
              Следующий
            </button>
          </div>

          <div class="donhin-form__step" data-step="2" hidden>
            <button type="button" class="donhin-btn donhin-btn--quiz-back" data-quiz-back>
              ← Назад к вопросу
            </button>
            <h3 class="donhin-form__heading">Запишитесь на бесплатную консультацию</h3>
            <label class="donhin-field">
              <span class="sr-only">Имя</span>
              <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
            </label>
            <label class="donhin-field">
              <span class="sr-only">Телефон</span>
              <input
                type="tel"
                name="phone"
                placeholder="Номер телефона"
                required
                autocomplete="tel"
                inputmode="tel"
                pattern="[0-9\-+() ]{9,18}"
              />
            </label>
            <label class="donhin-privacy">
              <input type="checkbox" name="privacy" required />
              <span>
                Я ознакомлен(а) с{' '}
                <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
                {' '}и согласен(а) на обработку моих данных (обязательно)
              </span>
            </label>
            <p class="donhin-error hidden" data-privacy-error role="alert"></p>
            <button type="submit" class="donhin-btn donhin-btn--primary">Отправить</button>
          </div>
          </div>
          <p class="donhin-status hidden" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    <section class="donhin-cases">
      <div class="donhin-container">
        <h2 class="donhin-section-title">Примеры кейсов</h2>
        <div class="donhin-cases__grid">
          {
            cases.map((item) => (
              <article class="donhin-case">
                <h3 class="donhin-case__title">{item.title}</h3>
                <p class="donhin-case__text">{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="donhin-about">
      <div class="donhin-container donhin-about__grid">
        <img
          src="/images/donhin/about-photo.webp"
          alt="Адвокат Саймон Донхин"
          class="donhin-about__photo"
          width="240"
          height="349"
          loading="lazy"
          decoding="async"
        />
        <div class="donhin-about__content">
          <h2 class="donhin-about__title">Адвокат Саймон Донхин</h2>
          <ul class="donhin-about__list">
            <li>Опытный адвокат с более чем 15-летним стажем работы</li>
            <li>Первая степень по юриспруденции — Кирьят Оно</li>
            <li>Вторая степень по криминологии — Еврейский университет</li>
            <li>Специализация по медицинской халатности</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="form-bottom" class="donhin-bottom-form">
      <div class="donhin-container donhin-bottom-form__inner">
        <h2 class="donhin-bottom-form__title">Оставьте заявку для бесплатной консультации</h2>

        <form class="donhin-form donhin-form--bottom" id="donhin-bottom-form" data-donhin-form="simple" novalidate>
          <label class="donhin-field">
            <span class="sr-only">Имя</span>
            <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
          </label>
          <label class="donhin-field">
            <span class="sr-only">Телефон</span>
            <input
              type="tel"
              name="phone"
              placeholder="Номер телефона"
              required
              autocomplete="tel"
              inputmode="tel"
              pattern="[0-9\-+() ]{9,18}"
            />
          </label>
          <label class="donhin-privacy">
            <input type="checkbox" name="privacy" required />
            <span>
              Я ознакомлен(а) с{' '}
              <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
              {' '}и согласен(а) на обработку моих данных (обязательно)
            </span>
          </label>
          <p class="donhin-error hidden" data-privacy-error role="alert"></p>
          <button type="submit" class="donhin-btn donhin-btn--brand donhin-btn--wide">Отправить</button>
          <p class="donhin-status hidden" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    <div id="donhin-scroll-sentinel" class="donhin-scroll-sentinel" aria-hidden="true"></div>
  </main>

  <div id="donhin-sticky-cta" class="donhin-sticky-cta hidden" hidden>
    <button type="button" id="donhin-sticky-cta-btn" class="donhin-sticky-cta__btn"></button>
  </div>

  <div
    id="donhin-popup"
    class="donhin-popup hidden"
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="donhin-popup-title"
    data-quiz-title={quizFormTitle}
  >
    <div class="donhin-popup__backdrop" data-popup-close></div>
    <div class="donhin-popup__panel">
      <button type="button" class="donhin-popup__close" data-popup-close aria-label="Закрыть">×</button>
      <h2 id="donhin-popup-title" class="donhin-popup__title">{quizFormTitle}</h2>

      <div id="donhin-popup-quiz-wrap">
      <form class="donhin-form donhin-form--quiz" id="donhin-popup-quiz-form" data-donhin-form="popup-quiz" novalidate>
        <div class="donhin-form__viewport">
          <div class="donhin-form__step is-active" data-step="1">
            <fieldset class="donhin-quiz">
              <legend class="donhin-quiz__question">
                Оказывалась ли вам медицинская или стоматологическая помощь в последние 7 лет?
              </legend>
              <div class="donhin-quiz__options">
                <label class="donhin-radio">
                  <input type="radio" name="popup_quiz" value="да" required />
                  <span>Да</span>
                </label>
                <label class="donhin-radio">
                  <input type="radio" name="popup_quiz" value="нет" />
                  <span>Нет</span>
                </label>
              </div>
            </fieldset>
            <button type="button" class="donhin-btn donhin-btn--quiz-action" data-quiz-next disabled>
              Следующий
            </button>
          </div>

          <div class="donhin-form__step" data-step="2" hidden>
            <button type="button" class="donhin-btn donhin-btn--quiz-back" data-quiz-back>
              ← Назад к вопросу
            </button>
            <h3 class="donhin-form__heading">Запишитесь на бесплатную консультацию</h3>
            <label class="donhin-field">
              <span class="sr-only">Имя</span>
              <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
            </label>
            <label class="donhin-field">
              <span class="sr-only">Телефон</span>
              <input
                type="tel"
                name="phone"
                placeholder="Номер телефона"
                required
                autocomplete="tel"
                inputmode="tel"
                pattern="[0-9\-+() ]{9,18}"
              />
            </label>
            <label class="donhin-privacy">
              <input type="checkbox" name="privacy" required />
              <span>
                Я ознакомлен(а) с{' '}
                <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
                {' '}и согласен(а) на обработку моих данных (обязательно)
              </span>
            </label>
            <p class="donhin-error hidden" data-privacy-error role="alert"></p>
            <button type="submit" class="donhin-btn donhin-btn--primary">Отправить</button>
          </div>
        </div>
        <p class="donhin-status hidden" data-status role="status" aria-live="polite"></p>
      </form>
      </div>

      <div id="donhin-popup-simple-wrap" class="donhin-popup__simple" hidden>
        <form class="donhin-form donhin-form--quiz donhin-form--popup-simple" id="donhin-popup-simple-form" data-donhin-form="popup-simple" novalidate>
          <label class="donhin-field">
            <span class="sr-only">Имя</span>
            <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
          </label>
          <label class="donhin-field">
            <span class="sr-only">Телефон</span>
            <input
              type="tel"
              name="phone"
              placeholder="Номер телефона"
              required
              autocomplete="tel"
              inputmode="tel"
              pattern="[0-9\-+() ]{9,18}"
            />
          </label>
          <label class="donhin-privacy">
            <input type="checkbox" name="privacy" required />
            <span>
              Я ознакомлен(а) с{' '}
              <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
              {' '}и согласен(а) на обработку моих данных (обязательно)
            </span>
          </label>
          <p class="donhin-error hidden" data-privacy-error role="alert"></p>
          <button type="submit" class="donhin-btn donhin-btn--primary">Отправить</button>
          <p class="donhin-status hidden" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>

  <Fragment slot="scripts">
<script is:inline src="/scripts/donhin-ab.js"></script>
<script is:inline>
  function readCookie(name) {
    var match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : '';
  }

  function collectTracking() {
    var url = new URL(window.location.href);
    var tracking = {};
    url.searchParams.forEach(function (value, key) {
      tracking[key] = value;
    });
    var fbc = readCookie('_fbc');
    var fbp = readCookie('_fbp');
    if (fbc) tracking.fbc = fbc;
    if (fbp) tracking.fbp = fbp;
    return tracking;
  }

  function collectUtm() {
    var url = new URL(window.location.href);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
    var utm = {};
    keys.forEach(function (key) {
      var value = url.searchParams.get(key);
      if (value) utm[key] = value;
    });
    return utm;
  }

  async function submitDonhinLead(form, formType) {
    var status = form.querySelector('[data-status]');
    var privacyError = form.querySelector('[data-privacy-error]');
    if (status) status.classList.add('hidden');
    if (privacyError) privacyError.classList.add('hidden');

    var nameInput = form.querySelector('input[name="name"]');
    var phoneInput = form.querySelector('input[name="phone"]');
    var privacyInput = form.querySelector('input[name="privacy"]');
    var quizInput = form.querySelector('.donhin-quiz input[type="radio"]:checked');
    var submitBtn = form.querySelector('[type="submit"]');

    if (!privacyInput || !privacyInput.checked) {
      if (privacyError) {
        privacyError.textContent = 'Необходимо согласие с политикой конфиденциальности';
        privacyError.classList.remove('hidden');
      }
      return;
    }

    var name = nameInput && nameInput.value.trim ? nameInput.value.trim() : '';
    var phone = phoneInput && phoneInput.value.trim ? phoneInput.value.trim() : '';
    if (!name || name.length < 2 || !phone || !/^[0-9\-+() ]{9,18}$/.test(phone)) return;

    var eventId = crypto.randomUUID();
    var originalLabel = submitBtn ? submitBtn.textContent : 'Отправить';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Отправка…';
    }

    var landingUrl = window.location.href;
    try {
      landingUrl = sessionStorage.getItem('pm_first_landing') || window.location.href;
    } catch (e) {}

    var lang = [navigator.language, navigator.userLanguage].filter(Boolean).join(' ');

    try {
      sessionStorage.setItem('donhin_lead_event_id', eventId);
    } catch (e) {}

    try {
      var res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name,
          phone: phone,
          client: 'donhin',
          formType: formType,
          quizAnswer: quizInput ? quizInput.value : '',
          pageUrl: window.location.href,
          landingUrl: landingUrl,
          referrer: document.referrer || '',
          utm: collectUtm(),
          tracking: Object.assign({}, collectUtm(), collectTracking()),
          language: lang,
          eventId: eventId,
        }),
      });

      var data = await res.json();
      if (!res.ok || !data.ok) throw new Error('submit failed');

      if (window.donhinAb && window.donhinAb.trackConversion) window.donhinAb.trackConversion();

      var main = document.getElementById('main-content');
      var basePath = main && main.dataset.donhinBasePath ? main.dataset.donhinBasePath : '/donhin';
      window.location.href = basePath + '/thank-you';
    } catch (e) {
      if (status) {
        status.textContent = 'Ошибка отправки. Попробуйте ещё раз.';
        status.classList.remove('hidden');
        status.setAttribute('role', 'alert');
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    }
  }

  function initQuizForm(quizForm) {
    var step1 = quizForm.querySelector('[data-step="1"]');
    var step2 = quizForm.querySelector('[data-step="2"]');
    var nextBtn = quizForm.querySelector('[data-quiz-next]');
    var backBtn = quizForm.querySelector('[data-quiz-back]');

    function goToStep(from, to, direction) {
      var leaving = direction === 'forward' ? 'is-leaving-forward' : 'is-leaving-back';
      var entering = direction === 'forward' ? 'is-entering-forward' : 'is-entering-back';

      from.classList.remove('is-active');
      from.classList.add(leaving);

      window.setTimeout(function () {
        from.classList.remove(leaving);
        from.setAttribute('hidden', '');

        to.removeAttribute('hidden');
        to.classList.add(entering);
        requestAnimationFrame(function () {
          to.classList.remove(entering);
          to.classList.add('is-active');
          if (direction === 'forward') {
            var nameField = quizForm.querySelector('input[name="name"]');
            if (nameField) nameField.focus();
          } else {
            var checked = quizForm.querySelector('.donhin-quiz input[type="radio"]:checked');
            if (checked) checked.focus();
          }
        });
      }, 280);
    }

    quizForm.querySelectorAll('.donhin-quiz input[type="radio"]').forEach(function (input) {
      input.addEventListener('change', function () {
        if (nextBtn) nextBtn.disabled = !quizForm.querySelector('.donhin-quiz input[type="radio"]:checked');
      });
    });

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        if (!quizForm.querySelector('.donhin-quiz input[type="radio"]:checked') || !step1 || !step2) return;
        goToStep(step1, step2, 'forward');
      });
    }

    if (backBtn) {
      backBtn.addEventListener('click', function () {
        if (!step1 || !step2) return;
        goToStep(step2, step1, 'back');
      });
    }

    quizForm.addEventListener('submit', function (e) {
      e.preventDefault();
      submitDonhinLead(quizForm, quizForm.dataset.donhinForm || 'quiz');
    });
  }

  function initDonhinPopup() {
    var popup = document.getElementById('donhin-popup');
    if (!popup) return;

    var ab = window.donhinAb;
    if (!ab) return;

    var popupQuizForm = document.getElementById('donhin-popup-quiz-form');
    var popupSimpleForm = document.getElementById('donhin-popup-simple-form');
    var quizWrap = document.getElementById('donhin-popup-quiz-wrap');
    var simpleWrap = document.getElementById('donhin-popup-simple-wrap');
    var title = document.getElementById('donhin-popup-title');
    var quizTitle = popup.dataset.quizTitle || 'Ответьте на вопрос — получите бесплатную консультацию адвоката';
    var assignments = ab.getAssignments();
    var autoSeenKey = 'donhin_popup_auto_seen';

    function isAutoSeen() {
      try {
        return sessionStorage.getItem(autoSeenKey) === '1';
      } catch (e) {
        return false;
      }
    }

    function markAutoSeen() {
      try {
        sessionStorage.setItem(autoSeenKey, '1');
      } catch (e) {}
    }

    function setPopupMode(mode) {
      if (mode === 'simple') {
        if (quizWrap) quizWrap.setAttribute('hidden', '');
        if (simpleWrap) simpleWrap.removeAttribute('hidden');
        if (title) title.textContent = 'Оставьте заявку для бесплатной консультации';
      } else {
        if (simpleWrap) simpleWrap.setAttribute('hidden', '');
        if (quizWrap) quizWrap.removeAttribute('hidden');
        if (title) title.textContent = quizTitle;
      }
    }

    function showPopupShell() {
      popup.hidden = false;
      popup.classList.remove('hidden');
      popup.classList.add('is-open');
      document.body.classList.add('donhin-popup-open');
    }

    function openPopup(trigger, options) {
      options = options || {};
      var force = options.force === true;
      var mode = options.mode || 'quiz';
      var isAuto = trigger === 'timer' || trigger === 'scroll';

      if (isAuto && !force && isAutoSeen()) return;
      if (popup.classList.contains('is-open') && !force) return;

