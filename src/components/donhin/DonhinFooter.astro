---
const year = new Date().getFullYear();
const pmLogoUrl = 'https://profitmedia.co.il/?utm_source=donhin';
---

<footer class="donhin-footer">
  <a href={pmLogoUrl} class="donhin-footer__logo" target="_blank" rel="noopener noreferrer">
    <img src="/logo.svg" alt="Profit Media" width="160" height="56" loading="lazy" decoding="async" />
  </a>
  <nav class="donhin-footer__nav" aria-label="קישורים משפטיים">
    <a href="/prat">מדיניות פרטיות</a>
    <a href="/hatzara">נגישות</a>
  </nav>
  <p class="donhin-footer__copy">© {year} Profit Media</p>
</footer>

<style>
  .donhin-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2.5rem 1.25rem 3rem;
    background: #000;
    text-align: center;
  }

  .donhin-footer__logo {
    display: inline-flex;
    opacity: 0.95;
    transition: opacity 0.2s ease;
  }

  .donhin-footer__logo:hover {
    opacity: 1;
  }

  .donhin-footer__logo img {
    height: 3.5rem;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .donhin-footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem 2rem;
  }

  .donhin-footer__nav a {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .donhin-footer__nav a:hover {
    color: #dddfff;
  }

  .donhin-footer__nav a:focus-visible {
    outline: 2px solid #dddfff;
    outline-offset: 3px;
    border-radius: 2px;
  }

  .donhin-footer__copy {
    margin: 0;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
  }
</style>
