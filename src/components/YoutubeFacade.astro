---
interface Props {
  youtubeId: string;
  title: string;
}

const { youtubeId, title } = Astro.props;
const thumb = `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`;
---

<div class="youtube-facade overflow-hidden rounded-xl bg-black shadow-lg">
  <div class="relative aspect-[9/16] w-full">
    <button
      type="button"
      class="youtube-facade__btn group absolute inset-0 flex h-full w-full items-center justify-center"
      data-youtube-id={youtubeId}
      data-youtube-title={title}
      aria-label={`נגן — ${title}`}
    >
      <img
        src={thumb}
        alt=""
        loading="lazy"
        decoding="async"
        width="480"
        height="360"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
      />
      <span class="youtube-facade__play" aria-hidden="true">
        <svg width="68" height="48" viewBox="0 0 68 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M66.52 7.74a8 8 0 0 0-5.63-5.66C55.3 1 34 1 34 1S12.7 1 7.11 2.08a8 8 0 0 0-5.63 5.66A83.2 83.2 0 0 0 0 24a83.2 83.2 0 0 0 1.48 16.26 8 8 0 0 0 5.63 5.66C12.7 47 34 47 34 47s21.3 0 26.89-1.08a8 8 0 0 0 5.63-5.66A83.2 83.2 0 0 0 68 24a83.2 83.2 0 0 0-1.48-16.26Z"
            fill="#212121"
            fill-opacity="0.8"></path>
          <path d="M45 24 27 14v20l18-10Z" fill="#fff"></path>
        </svg>
      </span>
    </button>
  </div>
</div>

<style>
  .youtube-facade__btn {
    cursor: pointer;
    border: none;
    padding: 0;
    background: transparent;
  }

  .youtube-facade__btn:focus-visible {
    outline: 2px solid #fcc000;
    outline-offset: 2px;
  }

  .youtube-facade__play {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.35));
    transition: transform 0.2s ease;
  }

  .youtube-facade__btn:hover .youtube-facade__play {
    transform: scale(1.06);
  }
</style>
