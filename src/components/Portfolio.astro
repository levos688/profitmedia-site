---
import SectionTitle from './SectionTitle.astro';
import HorizontalCarousel from './HorizontalCarousel.astro';
import Reveal from './Reveal.astro';
import OptimizedImage from './OptimizedImage.astro';
import { getPortfolioLandings } from '../data/site';

const portfolioLandings = getPortfolioLandings();
---

<section id="portfolio" class="section-padding below-fold bg-white">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <Reveal>
      <SectionTitle title="דפי נחיתה ממירים במיוחד" class="mb-10 md:mb-14" />
    </Reveal>

    <Reveal delay={100}>
      <HorizontalCarousel ariaLabel="גלריית דפי נחיתה" shuffle>
      {
        portfolioLandings.map((item) => (
          <article class="carousel-item landing-card">
            <button
              type="button"
              class="landing-card__btn"
              data-lightbox-trigger
              data-image={item.image}
              data-title={item.title}
              aria-label={`הגדל — ${item.title}`}
            >
              <div class="landing-card__frame">
                <OptimizedImage src={item.image} alt={item.title} width={700} height={1050} />
              </div>
              <p class="landing-card__caption">{item.title}</p>
            </button>
          </article>
        ))
      }
    </HorizontalCarousel>
    </Reveal>
  </div>

  <div
    id="landing-lightbox"
    class="lightbox hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="lightbox-title"
    hidden
  >
    <div class="lightbox__backdrop" data-lightbox-close></div>
    <div class="lightbox__panel">
      <button type="button" class="lightbox__close" data-lightbox-close aria-label="סגור">
        ✕
      </button>
      <button type="button" class="lightbox__nav lightbox__nav--prev" data-lightbox-prev aria-label="דף נחיתה קודם">
        ‹
      </button>
      <button type="button" class="lightbox__nav lightbox__nav--next" data-lightbox-next aria-label="דף נחיתה הבא">
        ›
      </button>
      <img id="lightbox-image" src="" alt="" class="lightbox__image" />
      <p id="lightbox-title" class="lightbox__title"></p>
    </div>
  </div>
</section>

<script>
  const lightbox = document.getElementById('landing-lightbox');
  const lightboxImg = document.getElementById('lightbox-image');
  const lightboxTitle = document.getElementById('lightbox-title');
  const prevBtn = lightbox?.querySelector('[data-lightbox-prev]');
  const nextBtn = lightbox?.querySelector('[data-lightbox-next]');
  let lastFocus: HTMLElement | null = null;
  let currentIndex = 0;
  let touchStartX = 0;

  const getSlides = () =>
    [
      ...document.querySelectorAll(
        '#portfolio .carousel-item:not([data-carousel-clone]) [data-lightbox-trigger]'
      ),
    ].map((btn) => ({
      image: (btn as HTMLElement).dataset.image || '',
      title: (btn as HTMLElement).dataset.title || '',
    }));

  const showSlide = (index: number) => {
    const slides = getSlides();
    if (!lightboxImg || !lightboxTitle || !slides.length) return;
    currentIndex = (index + slides.length) % slides.length;
    const item = slides[currentIndex];
    lightboxImg.src = item.image;
    lightboxImg.alt = item.title;
    lightboxTitle.textContent = item.title;
  };

  const openLightbox = (index: number, trigger: HTMLElement) => {
    if (!lightbox) return;
    lastFocus = trigger;
    showSlide(index);
    lightbox.hidden = false;
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    lightbox.querySelector<HTMLElement>('.lightbox__close')?.focus();
  };

  const closeLightbox = () => {
    if (!lightbox) return;
    lightbox.hidden = true;
    lightbox.classList.add('hidden');
    document.body.style.overflow = '';
    if (lightboxImg) lightboxImg.src = '';
    lastFocus?.focus();
  };

  const step = (delta: number) => showSlide(currentIndex + delta);

  document.getElementById('portfolio')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-lightbox-trigger]');
    if (!btn || btn.closest('[data-carousel-clone]')) return;
    const triggers = [
      ...document.querySelectorAll(
        '#portfolio .carousel-item:not([data-carousel-clone]) [data-lightbox-trigger]'
      ),
    ];
    const index = triggers.indexOf(btn);
    if (index === -1) return;
    openLightbox(index, btn as HTMLElement);
  });

  lightbox?.querySelectorAll('[data-lightbox-close]').forEach((el) => {
    el.addEventListener('click', closeLightbox);
  });

  prevBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    step(-1);
  });

  nextBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    step(1);
  });

  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0]?.screenX ?? 0;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    const touchEndX = e.changedTouches[0]?.screenX ?? 0;
    const delta = touchEndX - touchStartX;
    if (Math.abs(delta) < 40) return;
    step(delta < 0 ? 1 : -1);
  }, { passive: true });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') step(-1);
    if (e.key === 'ArrowRight') step(1);
  });
</script>

<style>
  .landing-card {
    width: min(calc(100vw - 6.5rem), 260px);
  }

  @media (min-width: 768px) {
    .landing-card {
      width: calc((min(100vw, 72rem) - 8rem) / 3);
      max-width: 340px;
    }
  }

  @media (min-width: 1024px) {
    .landing-card {
      width: calc((min(100vw, 72rem) - 9rem) / 3);
    }
  }

  .landing-card__btn {
    display: block;
    width: 100%;
    cursor: zoom-in;
    text-align: center;
    background: none;
    border: none;
    padding: 0;
  }

  .landing-card__btn:focus-visible {
    outline: 2px solid #651561;
    outline-offset: 4px;
    border-radius: 4px;
  }

  .landing-card__frame {
    aspect-ratio: 2 / 3;
    border-radius: 4px;
    border: 1px solid #e5e5e5;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.1);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .landing-card__btn:hover .landing-card__frame {
    box-shadow: 0 8px 24px rgb(101 21 97 / 0.18);
    transform: translateY(-2px);
  }

  .landing-card__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .landing-card__caption {
    margin-top: 0.625rem;
    padding-inline: 0.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #1f2937;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .landing-card__caption {
      font-size: 1rem;
    }
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .lightbox.hidden {
    display: none;
  }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.82);
    cursor: pointer;
  }

  .lightbox__panel {
    position: relative;
    z-index: 1;
    max-width: min(92vw, 520px);
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lightbox__close {
    position: absolute;
    top: -2.75rem;
    inset-inline-end: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: none;
    background: #fff;
    color: #651561;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    background: rgb(255 255 255 / 0.92);
    color: #651561;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.25);
    z-index: 2;
  }

  .lightbox__nav--prev {
    inset-inline-start: -3.25rem;
  }

  .lightbox__nav--next {
    inset-inline-end: -3.25rem;
  }

  .lightbox__nav:focus-visible,
  .lightbox__close:focus-visible {
    outline: 2px solid #fcc000;
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .lightbox__nav--prev {
      inset-inline-start: 0.25rem;
    }

    .lightbox__nav--next {
      inset-inline-end: 0.25rem;
    }
  }

  .lightbox__image {
    max-width: 100%;
    max-height: calc(92vh - 4rem);
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.4);
  }

  .lightbox__title {
    margin-top: 1rem;
    text-align: center;
    color: #fff;
    font-size: 1.0625rem;
    font-weight: 600;
  }
</style>
