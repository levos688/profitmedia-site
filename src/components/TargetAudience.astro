---
import SectionTitle from './SectionTitle.astro';
import { targetAudience } from '../data/site';
---

<section id="for-whom" class="target-audience section-padding below-fold bg-white reveal" data-reveal aria-labelledby="for-whom-title">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <SectionTitle
      id="for-whom-title"
      title={targetAudience.title}
      subtitle={targetAudience.subtitle}
      class="mb-12 md:mb-14"
    />

    <div class="target-audience__grid grid gap-5 sm:grid-cols-2" role="list">
      {
        targetAudience.items.map((item, index) => (
          <article class="audience-card" style={`--card-delay: ${index * 0.08}s`} role="listitem">
            <h3 class="audience-card__title">{item.title}</h3>
            <p class="audience-card__situation">{item.situation}</p>
            <p class="audience-card__outcome">
              <strong class="audience-card__outcome-label">התוצאה:</strong> {item.outcome}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .target-audience__grid .audience-card {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease-out,
      border-color 0.3s ease-out;
    transition-delay: var(--card-delay, 0s);
  }

  #for-whom.is-visible .target-audience__grid .audience-card {
    opacity: 1;
    transform: translateY(0);
  }

  .audience-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    padding: 1.5rem;
    text-align: right;
    background: linear-gradient(160deg, #fdfbff 0%, #fff 55%, #faf8fc 100%);
    border: 1px solid rgba(101, 21, 97, 0.1);
    border-radius: 4px;
    box-shadow: 0 8px 24px rgba(101, 21, 97, 0.06);
  }

  .audience-card:hover {
    border-color: rgba(101, 21, 97, 0.2);
    box-shadow: 0 16px 36px rgba(101, 21, 97, 0.1);
    transform: translateY(-2px);
  }

  .audience-card__title {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 800;
    color: #651561;
  }

  @media (min-width: 768px) {
    .audience-card {
      padding: 1.75rem;
    }

    .audience-card__title {
      font-size: 1.375rem;
    }
  }

  .audience-card__situation {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
    color: #374151;
  }

  .audience-card__outcome {
    margin: 0;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(101, 21, 97, 0.1);
    font-size: 0.975rem;
    line-height: 1.5;
    color: #111827;
  }

  .audience-card__outcome-label {
    font-weight: 800;
    color: #651561;
  }

  @media (prefers-reduced-motion: reduce) {
    .target-audience__grid .audience-card {
      opacity: 1;
      transform: none;
      transition: box-shadow 0.3s ease-out, border-color 0.3s ease-out;
    }
  }
</style>
