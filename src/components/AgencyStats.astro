---
import { agencyStats } from '../data/site';
import Reveal from './Reveal.astro';
---

<section class="agency-stats section-padding below-fold" aria-label="מספרים על העסק">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <Reveal>
      <div class="agency-stats__panel">
        <header class="agency-stats__header">
          <p class="agency-stats__eyebrow">נתונים מהפעילות שלנו</p>
          <h2 class="agency-stats__title">ניסיון ותוצאות במספרים</h2>
        </header>

        <div class="agency-stats__row">
          {
            agencyStats.map((item) => (
              <div class="agency-stats__item">
                <p
                  class="agency-stats__value"
                  data-stat-counter
                  data-count={item.count}
                  data-suffix={item.suffix}
                  data-prefix={item.prefix ?? ''}
                >
                  <span dir="ltr">{item.prefix ?? ''}{item.count}{item.suffix}</span>
                </p>
                <p class="agency-stats__label">{item.label}</p>
                {item.note && <p class="agency-stats__note">{item.note}</p>}
              </div>
            ))
          }
        </div>
      </div>
    </Reveal>
  </div>
</section>

<script>
  // Proof stats stay static. Count-up animations previously left mid-values
  // (e.g. "7+", "₪0M+") when the frame was interrupted — unacceptable for trust.
  const counters = document.querySelectorAll<HTMLElement>('[data-stat-counter]');

  const renderFinal = (el: HTMLElement) => {
    const span = el.querySelector('span');
    if (!span) return;
    const target = Number(el.dataset.count || 0);
    const suffix = el.dataset.suffix || '';
    const prefix = el.dataset.prefix || '';
    span.textContent = `${prefix}${target}${suffix}`;
  };

  counters.forEach(renderFinal);
</script>

<style>
  .agency-stats {
    background: linear-gradient(160deg, #f8f4fa 0%, #fff 50%, #faf8fc 100%);
  }

  .agency-stats__panel {
    padding: 2rem 1.5rem;
    border-radius: 1.5rem;
    background: #fff;
    border: 1px solid rgba(101, 21, 97, 0.08);
    box-shadow: 0 12px 40px rgba(101, 21, 97, 0.08);
  }

  @media (min-width: 768px) {
    .agency-stats__panel {
      padding: 2.5rem 2rem;
    }
  }

  .agency-stats__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .agency-stats__eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #c60691;
  }

  .agency-stats__title {
    margin-top: 0.75rem;
    font-size: 1.875rem;
    line-height: 1.2;
    font-weight: 800;
    color: #111827;
  }

  @media (min-width: 768px) {
    .agency-stats__title {
      font-size: 2.25rem;
    }
  }

  .agency-stats__row {
    display: grid;
    gap: 1.5rem;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .agency-stats__row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
    }
  }

  .agency-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    width: 100%;
    padding-inline: 0.5rem;
  }

  @media (min-width: 768px) {
    .agency-stats__item + .agency-stats__item {
      border-inline-start: 1px solid rgba(101, 21, 97, 0.15);
      padding-inline-start: 1rem;
      margin-inline-start: 1rem;
    }
  }

  .agency-stats__value {
    margin: 0;
    min-height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-size: clamp(2rem, 4.5vw, 2.5rem);
    font-weight: 900;
    line-height: 1;
    color: #651561;
  }

  .agency-stats__value span {
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .agency-stats__label {
    margin: 0.75rem 0 0;
    min-height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 14rem;
    font-size: 1.125rem;
    font-weight: 800;
    line-height: 1.35;
    color: #111827;
    text-align: center;
  }

  .agency-stats__note {
    margin: 0.5rem 0 0;
    max-width: 14rem;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: #6b7280;
    text-align: center;
  }
</style>
