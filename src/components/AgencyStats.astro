---
import { agencyStats } from '../data/site';
import Reveal from './Reveal.astro';
---

<section class="agency-stats section-padding below-fold" aria-label="מספרים על העסק">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <Reveal>
      <div class="agency-stats__panel">
        <header class="agency-stats__header">
          <p class="agency-stats__eyebrow">נתונים מהפעילות שלנו</p>
          <h2 class="agency-stats__title">ניסיון ותוצאות במספרים</h2>
        </header>

        <ul class="agency-stats__row">
          {
            agencyStats.map((item) => (
              <li class="agency-stats__item">
                <p
                  class="agency-stats__value"
                  data-stat-counter
                  data-count={item.count}
                  data-suffix={item.suffix}
                  data-prefix={item.prefix ?? ''}
                >
                  <span dir="ltr">{item.prefix ?? ''}{item.count}{item.suffix}</span>
                </p>
                <p class="agency-stats__label">{item.label}</p>
                {item.note && <p class="agency-stats__note">{item.note}</p>}
              </li>
            ))
          }
        </ul>
      </div>
    </Reveal>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('[data-stat-counter]');

  const formatCount = (value: number, prefix: string, suffix: string) => `${prefix}${value}${suffix}`;

  const animateCounter = (el: HTMLElement) => {
    const target = Number(el.dataset.count || 0);
    const suffix = el.dataset.suffix || '';
    const prefix = el.dataset.prefix || '';
    const span = el.querySelector('span');
    if (!span) return;

    const duration = target > 1000 ? 1800 : 1400;
    const start = performance.now();

    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(target * eased);
      span.textContent = formatCount(current, prefix, suffix);
      if (progress < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    counters.forEach((el) => {
      const node = el as HTMLElement;
      const span = node.querySelector('span');
      if (span) {
        span.textContent = formatCount(
          Number(node.dataset.count || 0),
          node.dataset.prefix || '',
          node.dataset.suffix || ''
        );
      }
    });
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.35 }
    );
    counters.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .agency-stats {
    background: linear-gradient(160deg, #f8f4fa 0%, #fff 50%, #faf8fc 100%);
  }

  .agency-stats__panel {
    padding: 2rem 1.5rem;
    border-radius: 1.5rem;
    background: #fff;
    border: 1px solid rgba(101, 21, 97, 0.08);
    box-shadow: 0 12px 40px rgba(101, 21, 97, 0.08);
  }

  @media (min-width: 768px) {
    .agency-stats__panel {
      padding: 2.5rem 2rem;
    }
  }

  .agency-stats__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .agency-stats__eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #c60691;
  }

  .agency-stats__title {
    margin-top: 0.75rem;
    font-size: 1.875rem;
    line-height: 1.2;
    font-weight: 800;
    color: #111827;
  }

  @media (min-width: 768px) {
    .agency-stats__title {
      font-size: 2.25rem;
    }
  }

  .agency-stats__row {
    display: grid;
    gap: 1.5rem;
    align-items: stretch;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .agency-stats__row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
    }
  }

  .agency-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    width: 100%;
    padding-inline: 0.5rem;
  }

  @media (min-width: 768px) {
    .agency-stats__item + .agency-stats__item {
      border-inline-start: 1px solid rgba(101, 21, 97, 0.15);
      padding-inline-start: 1rem;
      margin-inline-start: 1rem;
    }
  }

  .agency-stats__value {
    margin: 0;
    min-height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-size: clamp(2rem, 4.5vw, 2.5rem);
    font-weight: 900;
    line-height: 1;
    color: #651561;
  }

  .agency-stats__value span {
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .agency-stats__label {
    margin: 0.75rem 0 0;
    min-height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 14rem;
    font-size: 1.125rem;
    font-weight: 800;
    line-height: 1.35;
    color: #111827;
    text-align: center;
  }

  .agency-stats__note {
    margin: 0.5rem 0 0;
    max-width: 14rem;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: #6b7280;
    text-align: center;
  }
</style>
