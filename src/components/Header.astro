---
const nav = [
  { href: '#services', label: 'שירותים' },
  { href: '#testimonials', label: 'עדויות' },
  { href: '#portfolio', label: 'דפי נחיתה' },
  { href: '#clients', label: 'לקוחות' },
  { href: '#contact', label: 'צור קשר' },
];
---

<header class="site-header sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur transition-shadow duration-300" id="site-header">
  <div class="header-bar mx-auto flex max-w-6xl items-center gap-4 px-4 py-3 md:px-6 lg:flex-row">
    <a href="/" class="header-logo block shrink-0" aria-label="Profit Media — דף הבית">
      <img src="/logo.svg" alt="Profit Media" class="h-10 w-auto md:h-[70px]" width="200" height="70" />
    </a>

    <nav class="hidden min-w-0 flex-1 items-center justify-end gap-1 lg:flex" aria-label="ניווט ראשי">
      {
        nav.map((item) => (
          <a href={item.href} class="nav-link" data-nav-link={item.href.slice(1)}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a href="#contact" class="btn-yellow hidden shrink-0 rounded-full px-5 py-2 text-sm font-black lg:inline-flex">
      אבחון חינם
    </a>

    <button
      type="button"
      id="mobile-menu-btn"
      class="mobile-menu-btn ms-auto lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="פתיחת תפריט"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M4 7h16M4 12h16M4 17h16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="mobile-menu hidden border-t border-gray-100 bg-white lg:hidden"
    aria-label="ניווט נייד"
    hidden
  >
    <div class="mx-auto max-w-6xl px-4 py-4">
      <ul class="space-y-1">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="mobile-nav-link" data-nav-link={item.href.slice(1)}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href="#contact" class="btn-yellow mt-4 flex w-full items-center justify-center rounded-full py-3 text-base font-black">
        אבחון חינם
      </a>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  const setMenuOpen = (open: boolean) => {
    if (!menuBtn || !mobileMenu) return;
    menuBtn.setAttribute('aria-expanded', String(open));
    menuBtn.setAttribute('aria-label', open ? 'סגירת תפריט' : 'פתיחת תפריט');
    mobileMenu.hidden = !open;
    mobileMenu.classList.toggle('hidden', !open);
  };

  menuBtn?.addEventListener('click', () => {
    const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!isOpen);
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuBtn?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      menuBtn.focus();
    }
  });

  const siteHeader = document.getElementById('site-header');

  const sectionIds = ['services', 'testimonials', 'portfolio', 'clients', 'contact'];
  const navLinks = document.querySelectorAll('[data-nav-link]');
  const sectionTops = new Map<string, number>();

  const measureSections = () => {
    sectionTops.clear();
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el) sectionTops.set(id, el.offsetTop);
    }
  };

  let navTicking = false;
  const updateActiveNav = () => {
    navTicking = false;
    const scrollY = window.scrollY + 120;
    let current = '';
    for (const id of sectionIds) {
      const top = sectionTops.get(id);
      if (top !== undefined && top <= scrollY) current = id;
    }
    navLinks.forEach((link) => {
      const href = link.getAttribute('data-nav-link');
      link.classList.toggle('nav-link--active', href === current);
    });
  };

  const queueActiveNav = () => {
    if (navTicking) return;
    navTicking = true;
    requestAnimationFrame(updateActiveNav);
  };

  let headerTicking = false;
  const onHeaderScroll = () => {
    headerTicking = false;
    if (!siteHeader) return;
    siteHeader.classList.toggle('site-header--scrolled', window.scrollY > 12);
  };

  const queueHeaderScroll = () => {
    if (headerTicking) return;
    headerTicking = true;
    requestAnimationFrame(onHeaderScroll);
  };

  measureSections();
  window.addEventListener('scroll', queueActiveNav, { passive: true });
  window.addEventListener('scroll', queueHeaderScroll, { passive: true });
  window.addEventListener('resize', measureSections, { passive: true });
  updateActiveNav();
  onHeaderScroll();
</script>

<style>
  .site-header--scrolled {
    box-shadow: 0 8px 28px rgba(101, 21, 97, 0.08);
    border-color: rgba(101, 21, 97, 0.08);
  }

  @media (max-width: 1023px) {
    .header-bar {
      flex-direction: row;
      direction: ltr;
      justify-content: space-between;
    }
  }
</style>
