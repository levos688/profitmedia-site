---
import { targetAudience, processSteps, hero, homeSeo, faqs } from '../data/site';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://profitmedia.co.il/#organization',
  name: 'Profit Media',
  alternateName: 'פרופיט מדיה',
  url: 'https://profitmedia.co.il/',
  logo: 'https://profitmedia.co.il/icons/site-icon.png',
  image: 'https://profitmedia.co.il/icons/site-icon.png',
  description: homeSeo.description,
  inLanguage: 'he-IL',
  areaServed: {
    '@type': 'Country',
    name: 'Israel',
  },
  serviceType: [
    'ניהול קמפיינים בפייסבוק',
    'ניהול קמפיינים באינסטגרם',
    'ניהול קמפיינים בגוגל',
    'בניית דפי נחיתה',
    'שאלונים לסינון לידים',
    'יצירת לידים לעסקאות גבוהות',
  ],
  knowsAbout: [
    'Facebook Ads',
    'Google Ads',
    'Instagram Ads',
    'Landing pages',
    'Lead generation',
    'Lead qualification',
    'A/B testing',
    'Interactive quizzes',
    'High-ticket sales',
  ],
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'עסקים עם עסקאות גבוהות שנמכרים בשיחה, בוואטסאפ או בפגישה',
  },
  availableLanguage: ['he', 'en'],
};

const audienceListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': 'https://profitmedia.co.il/#for-whom',
  name: targetAudience.title,
  description: targetAudience.subtitle,
  itemListElement: targetAudience.items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.title,
    description: `${item.situation} ${item.outcome}`,
  })),
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': 'https://profitmedia.co.il/#how-it-works',
  name: 'איך Profit Media מביאה עסקאות מהפרסום',
  description: processSteps.subtitle,
  step: processSteps.steps.map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    name: step.title,
    text: step.description,
  })),
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://profitmedia.co.il/#website',
  url: 'https://profitmedia.co.il/',
  name: 'Profit Media',
  description: homeSeo.description,
  inLanguage: 'he-IL',
  publisher: {
    '@id': 'https://profitmedia.co.il/#organization',
  },
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://profitmedia.co.il/#webpage',
  url: homeSeo.canonical,
  name: homeSeo.title,
  description: homeSeo.description,
  inLanguage: 'he-IL',
  isPartOf: {
    '@id': 'https://profitmedia.co.il/#website',
  },
  about: {
    '@id': 'https://profitmedia.co.il/#organization',
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: 'https://profitmedia.co.il/images/hero/photo-min.svg',
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: hero.title,
  description: hero.subtitle,
  provider: {
    '@id': 'https://profitmedia.co.il/#organization',
  },
  areaServed: {
    '@type': 'Country',
    name: 'Israel',
  },
  serviceType: 'ניהול קמפיינים ולידים לעסקים עם עסקאות גבוהות',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://profitmedia.co.il/#faq',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    organizationSchema,
    websiteSchema,
    webPageSchema,
    serviceSchema,
    audienceListSchema,
    howToSchema,
    faqSchema,
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
