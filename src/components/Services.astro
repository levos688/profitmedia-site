---
import SectionTitle from './SectionTitle.astro';
import { services } from '../data/site';
---

<section id="services" class="section-padding bg-white reveal" data-reveal>
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <SectionTitle
      title="שירותים עיקריים"
      subtitle="פרסום ממוקד תוצאה — מקמפיין ועד דף נחיתה שממיר"
      class="mb-12 md:mb-16"
    />

    <div class="services-grid grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service) => (
          <article class="service-card h-full">
              <img
                src={service.icon}
                alt=""
                aria-hidden="true"
                width="180"
                height="180"
                class="service-card__icon"
                loading="lazy"
              />
            <h3 class="service-card__title">{service.title}</h3>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services-grid .service-card {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s ease-out,
      border-color 0.25s ease-out;
  }

  #services.is-visible .services-grid .service-card {
    opacity: 1;
    transform: translateY(0);
  }

  #services.is-visible .services-grid .service-card:nth-child(1) {
    transition-delay: 0.08s;
  }
  #services.is-visible .services-grid .service-card:nth-child(2) {
    transition-delay: 0.16s;
  }
  #services.is-visible .services-grid .service-card:nth-child(3) {
    transition-delay: 0.24s;
  }
  #services.is-visible .services-grid .service-card:nth-child(4) {
    transition-delay: 0.32s;
  }

  @media (prefers-reduced-motion: reduce) {
    .services-grid .service-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
