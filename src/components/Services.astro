---
import SectionTitle from './SectionTitle.astro';
import { services } from '../data/site';
---

<section id="services" class="section-padding below-fold bg-white reveal" data-reveal>
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <SectionTitle
      title="מערכת עסקאות מהפרסום — מה בפנים"
      subtitle="אסטרטגיה, תשתית המרה וניהול קמפיינים שעובדים יחד כמערכת אחת"
      class="mb-12 md:mb-16"
    />

    <div class="services-grid grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service, index) => (
          <article class="service-card h-full" style={`--card-delay: ${index * 0.08}s`}>
            <div class="service-card__icon-wrap">
              <img
                src={service.icon}
                alt=""
                aria-hidden="true"
                width="92"
                height="92"
                class="service-card__icon"
                loading="lazy"
              />
            </div>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__description">{service.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services-grid .service-card {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease-out,
      border-color 0.3s ease-out;
    transition-delay: var(--card-delay, 0s);
  }

  #services.is-visible .services-grid .service-card {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card__icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 9rem;
    height: 9rem;
    margin-bottom: 1.25rem;
    border-radius: 50%;
    background: #f4eef5;
  }

  .service-card__icon-wrap::before {
    content: '';
    position: absolute;
    inset: 12%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(101, 21, 97, 0.1) 0%, transparent 72%);
    opacity: 0;
    transform: scale(0.9);
    transition:
      opacity 0.45s ease,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .service-card:hover .service-card__icon-wrap::before {
    opacity: 1;
    transform: scale(1);
  }

  .service-card__icon {
    position: relative;
    z-index: 1;
    width: 5.75rem;
    height: 5.75rem;
    object-fit: contain;
    margin-bottom: 0;
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.45s ease;
  }

  .service-card:hover .service-card__icon {
    transform: translateY(-5px);
    filter: drop-shadow(0 10px 12px rgba(101, 21, 97, 0.14));
  }

  #services.is-visible .service-card__icon {
    animation: service-icon-reveal 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--card-delay, 0s) + 0.15s);
  }

  @keyframes service-icon-reveal {
    from {
      opacity: 0.4;
      transform: scale(0.94);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-grid .service-card {
      opacity: 1;
      transform: none;
      transition: none;
    }

    #services.is-visible .service-card__icon {
      animation: none;
    }
  }
</style>
