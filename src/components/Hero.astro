---
import HeroIllustration from './HeroIllustration.astro';
import { hero } from '../data/site';
---

<section
  class="hero-gradient relative overflow-hidden pb-10 pt-4 md:pb-16 md:pt-6"
  aria-labelledby="hero-title"
>
  <div class="hero-gradient__pattern" aria-hidden="true"></div>
  <div class="hero-gradient__mesh" aria-hidden="true"></div>

  <img
    src="/images/hero/image_2_traced.svg"
    alt=""
    aria-hidden="true"
    class="hero-decoration pointer-events-none absolute -top-24 start-0 w-72 opacity-90 md:w-96"
  />
  <img
    src="/images/hero/image_2_traced.svg"
    alt=""
    aria-hidden="true"
    class="hero-decoration pointer-events-none absolute -top-20 end-0 hidden w-72 opacity-90 lg:block lg:w-96"
  />

  <div class="relative mx-auto max-w-6xl px-4 md:px-6">
    <div class="grid items-center gap-10 py-6 md:gap-14 md:py-10 lg:grid-cols-2">
      <div class="hero-content text-right text-white max-md:text-center">
        <p class="hero-eyebrow text-sm font-bold tracking-wide text-white/90 md:text-base">
          {hero.eyebrow}
        </p>
        <h1 id="hero-title" class="mt-4 text-4xl leading-tight font-bold md:text-[52px] lg:text-[56px]">
          {hero.title}
        </h1>
        <p class="hero-subtitle mt-6 text-lg leading-relaxed text-white/95 md:text-2xl lg:mt-7">
          {hero.subtitle}
        </p>
        <div class="hero-cta-group mt-8 md:mt-10">
          <a
            href="#contact"
            class="btn-yellow hero-cta rounded-full px-8 py-3.5 text-lg font-bold shadow-lg md:px-10 md:py-4 md:text-xl"
          >
            {hero.cta}
          </a>
          <p class="hero-cta-note text-sm text-white/80 md:text-base">
            {hero.ctaNote}
          </p>
        </div>
      </div>

      <div class="hero-visual flex justify-center lg:justify-start">
        <HeroIllustration />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-gradient__pattern {
    position: absolute;
    inset: -25%;
    opacity: 0.055;
    background-image: url('/images/hero/image_2_traced.svg');
    background-size: 280px auto;
    background-repeat: repeat;
    pointer-events: none;
  }

  .hero-decoration {
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .hero-decoration {
      display: none;
    }
  }

  .hero-eyebrow {
    letter-spacing: 0.02em;
  }

  .hero-subtitle {
    max-width: 36rem;
  }

  @media (min-width: 1024px) {
    .hero-subtitle {
      margin-inline-start: 0;
      margin-inline-end: auto;
    }
  }

  .hero-cta-group {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-cta-note {
    width: 100%;
    text-align: center;
  }

  .hero-gradient__mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 15% 25%, rgba(255, 255, 255, 0.1), transparent 55%),
      radial-gradient(ellipse 65% 50% at 85% 75%, rgba(198, 6, 145, 0.12), transparent 52%);
  }

  @media (max-width: 767px) {
    .hero-cta-group {
      width: 100%;
    }

    .hero-cta {
      width: 100%;
      justify-content: center;
    }

    .hero-subtitle {
      margin-inline: auto;
    }
  }

  @media (min-width: 768px) {
    .hero-content {
      animation: hero-fade-up 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .hero-visual {
      animation: hero-fade-up 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.12s both;
    }

    .hero-cta-group {
      align-items: flex-start;
    }

    .hero-cta-note {
      text-align: right;
    }
  }

  .hero-cta {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
  }

  @keyframes hero-fade-up {
    from {
      transform: translateY(24px);
    }
    to {
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content,
    .hero-visual {
      animation: none;
    }
  }
</style>
