---
import HeroIllustration from './HeroIllustration.astro';
---

<section class="hero-gradient relative overflow-hidden pb-10 pt-4 md:pb-16 md:pt-6">
  <div class="hero-gradient__mesh" aria-hidden="true"></div>
  <div class="hero-gradient__orb hero-gradient__orb--soft" aria-hidden="true"></div>

  <img
    src="/images/hero/image_2_traced.svg"
    alt=""
    aria-hidden="true"
    class="hero-decoration pointer-events-none absolute -top-24 start-0 w-72 opacity-90 md:w-96"
  />
  <img
    src="/images/hero/image_2_traced.svg"
    alt=""
    aria-hidden="true"
    class="hero-decoration hero-decoration--delay pointer-events-none absolute -top-20 end-0 hidden w-72 opacity-90 lg:block lg:w-96"
  />

  <div class="relative mx-auto max-w-6xl px-4 md:px-6">
    <div class="grid items-center gap-10 py-6 md:gap-14 md:py-10 lg:grid-cols-2">
      <div class="hero-content text-right text-white">
        <h1 class="text-4xl leading-tight font-bold md:text-[52px] lg:text-[56px]">
          פרסום טוב לא עולה כסף - הוא מכניס כסף
        </h1>
        <p class="mt-7 text-xl leading-relaxed md:text-[30px] lg:mt-8">
          כשהקמפיין בנוי נכון, כל שקל שנכנס מביא שלושה בחזרה.
        </p>
        <div class="mt-10 flex flex-col items-start gap-3 md:mt-12">
          <a
            href="#contact"
            class="btn-yellow hero-cta rounded-full px-8 py-3.5 text-lg font-black shadow-lg md:px-10 md:py-4 md:text-xl"
          >
            השאר פרטים וקבל אבחון חינם
          </a>
          <p class="text-sm text-white/80 md:text-base">ללא התחייבות • מענה תוך 24 שעות</p>
        </div>
      </div>

      <div class="hero-visual flex justify-center lg:justify-start">
        <HeroIllustration />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-gradient__mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 15% 25%, rgba(255, 255, 255, 0.1), transparent 55%),
      radial-gradient(ellipse 65% 50% at 85% 75%, rgba(198, 6, 145, 0.12), transparent 52%);
    animation: hero-mesh-shift 16s ease-in-out infinite alternate;
  }

  .hero-gradient__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-gradient__orb--soft {
    bottom: 8%;
    inset-inline-start: 10%;
    width: 18rem;
    height: 18rem;
    background: rgba(255, 255, 255, 0.08);
    animation: hero-orb-float 14s ease-in-out infinite;
  }

  .hero-decoration {
    animation: hero-decoration-float 10s ease-in-out infinite;
  }

  .hero-decoration--delay {
    animation-delay: -4s;
  }

  .hero-content {
    animation: hero-fade-up 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-visual {
    animation: hero-fade-up 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.12s both;
  }

  .hero-cta {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
  }

  @keyframes hero-mesh-shift {
    from {
      transform: scale(1);
      opacity: 0.9;
    }
    to {
      transform: scale(1.04);
      opacity: 1;
    }
  }

  @keyframes hero-orb-float {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(10px, -14px);
    }
  }

  @keyframes hero-decoration-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gradient__mesh,
    .hero-gradient__orb,
    .hero-decoration,
    .hero-content,
    .hero-visual {
      animation: none;
    }
  }
</style>
