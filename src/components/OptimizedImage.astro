---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  width,
  height,
  class: className = '',
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

const webpSrc = src.replace(/\.jpe?g$/i, '.webp');
---

<picture>
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
  />
</picture>
