---
interface Props {
  ariaLabel: string;
  gap?: 'normal' | 'wide';
  shuffle?: boolean;
  loop?: boolean;
}

const { ariaLabel, gap = 'normal', shuffle = false, loop = true } = Astro.props;
const uid = `carousel-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={['carousel-outer', gap === 'wide' && 'carousel-outer--wide']}
  role="region"
  aria-label={ariaLabel}
  data-carousel-root={uid}
>
  <!-- RTL: first = right edge, arrow → scrolls forward -->
  <button
    type="button"
    class="carousel-arrow carousel-arrow--edge-start"
    aria-label="גלול קדימה"
    data-carousel-start={uid}
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M9 6l6 6-6 6"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>

  <div class="carousel-wrap">
    <div class="carousel-track" data-carousel-track={uid} tabindex="0">
      <slot />
    </div>
  </div>

  <!-- RTL: last = left edge, arrow ← scrolls backward -->
  <button
    type="button"
    class="carousel-arrow carousel-arrow--edge-end"
    aria-label="גלול אחורה"
    data-carousel-end={uid}
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M15 6l-6 6 6 6"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
</div>

<script define:vars={{ uid, shuffle, loop }}>
  (() => {
    const root = document.querySelector(`[data-carousel-root="${uid}"]`);
    const track = document.querySelector(`[data-carousel-track="${uid}"]`);
    const startBtn = document.querySelector(`[data-carousel-start="${uid}"]`);
    const endBtn = document.querySelector(`[data-carousel-end="${uid}"]`);
    if (!root || !track || !startBtn || !endBtn) return;

    const getRealItems = () =>
      [...track.querySelectorAll(':scope > .carousel-item:not([data-carousel-clone])')];
    const getAllItems = () => [...track.querySelectorAll(':scope > .carousel-item')];

    if (shuffle) {
      const items = getRealItems();
      for (let i = items.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [items[i], items[j]] = [items[j], items[i]];
      }
      items.forEach((item) => track.appendChild(item));
    }

    let loopEnabled = false;
    let realCount = 0;
    let index = 0;
    let busy = false;
    let settleTimer = 0;
    let ready = false;

    const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = () => window.matchMedia('(max-width: 767px)').matches;

    const targetLeftFor = (item) => {
      if (!item) return 0;
      const left = isMobile()
        ? item.offsetLeft - (track.clientWidth - item.offsetWidth) / 2
        : item.offsetLeft;
      const max = Math.max(0, track.scrollWidth - track.clientWidth);
      return Math.min(max, Math.max(0, left));
    };

    const syncIndexFromScroll = () => {
      const items = getAllItems();
      if (!items.length) return 0;
      const focus = isMobile()
        ? track.scrollLeft + track.clientWidth / 2
        : track.scrollLeft + Math.min(24, track.clientWidth * 0.1);
      let best = 0;
      let bestDist = Infinity;
      items.forEach((item, i) => {
        const point = isMobile()
          ? item.offsetLeft + item.offsetWidth / 2
          : item.offsetLeft;
        const dist = Math.abs(point - focus);
        if (dist < bestDist) {
          bestDist = dist;
          best = i;
        }
      });
      index = best;
      return best;
    };

    const jumpToIndex = (nextIndex) => {
      const items = getAllItems();
      const item = items[nextIndex];
      if (!item) return;
      index = nextIndex;
      track.scrollLeft = targetLeftFor(item);
    };

    const goToIndex = (nextIndex, smooth) => {
      const items = getAllItems();
      if (!items[nextIndex] || busy) return;

      busy = true;
      window.clearTimeout(settleTimer);
      index = nextIndex;

      const useSmooth = smooth && !reduceMotion();
      track.scrollTo({ left: targetLeftFor(items[nextIndex]), behavior: useSmooth ? 'smooth' : 'auto' });

      const finish = () => {
        window.clearTimeout(settleTimer);
        if (loopEnabled && realCount > 0) {
          if (index < realCount) {
            jumpToIndex(index + realCount);
          } else if (index >= realCount * 2) {
            jumpToIndex(index - realCount);
          } else {
            // Re-align in case snap / subpixel drift left a half card
            jumpToIndex(index);
          }
        }
        busy = false;
        updateArrows();
      };

      if (!useSmooth) {
        finish();
        return;
      }

      settleTimer = window.setTimeout(finish, 380);
    };

    const step = (delta) => {
      if (!ready) init();
      if (busy) return;
      syncIndexFromScroll();
      const next = index + delta;
      const items = getAllItems();
      if (next < 0 || next >= items.length) return;
      goToIndex(next, true);
    };

    const setupLoop = () => {
      const items = getRealItems();
      realCount = items.length;
      if (!loop || realCount < 2) {
        loopEnabled = false;
        index = 0;
        return;
      }

      const before = document.createDocumentFragment();
      const after = document.createDocumentFragment();

      items.forEach((item) => {
        const cloneBefore = item.cloneNode(true);
        const cloneAfter = item.cloneNode(true);
        [cloneBefore, cloneAfter].forEach((clone) => {
          clone.setAttribute('data-carousel-clone', '');
          clone.setAttribute('aria-hidden', 'true');
          clone.querySelectorAll('button, a, input, select, textarea').forEach((el) => {
            el.setAttribute('tabindex', '-1');
          });
        });
        before.appendChild(cloneBefore);
        after.appendChild(cloneAfter);
      });

      track.insertBefore(before, track.firstChild);
      track.appendChild(after);
      loopEnabled = true;
      index = realCount;
    };

    const updateArrows = () => {
      if (loopEnabled) {
        startBtn.disabled = false;
        endBtn.disabled = false;
        return;
      }
      const max = Math.max(0, track.scrollWidth - track.clientWidth);
      startBtn.disabled = max <= 1;
      endBtn.disabled = max <= 1;
    };

    const applyLayout = () => {
      if (loopEnabled) {
        jumpToIndex(Math.min(Math.max(index, realCount), realCount * 2 - 1) || realCount);
      } else {
        jumpToIndex(Math.min(index, Math.max(0, getAllItems().length - 1)));
      }
      updateArrows();
    };

    const init = () => {
      if (ready) return;
      ready = true;
      setupLoop();
      requestAnimationFrame(() => {
        requestAnimationFrame(applyLayout);
      });
    };

    startBtn.addEventListener('click', (event) => {
      event.preventDefault();
      step(1);
    });
    endBtn.addEventListener('click', (event) => {
      event.preventDefault();
      step(-1);
    });

    track.addEventListener(
      'scroll',
      () => {
        if (busy) return;
        window.clearTimeout(settleTimer);
        settleTimer = window.setTimeout(() => {
          syncIndexFromScroll();
          if (!loopEnabled) {
            updateArrows();
            return;
          }
          if (index < realCount) {
            jumpToIndex(index + realCount);
          } else if (index >= realCount * 2) {
            jumpToIndex(index - realCount);
          }
          updateArrows();
        }, 120);
      },
      { passive: true }
    );

    window.addEventListener('resize', () => {
      if (!ready) return;
      window.clearTimeout(settleTimer);
      settleTimer = window.setTimeout(() => {
        syncIndexFromScroll();
        applyLayout();
      }, 100);
    });

    // Init as soon as the carousel is near the viewport, or immediately if already visible
    const boot = () => {
      const rect = root.getBoundingClientRect();
      const near =
        rect.bottom > -240 && rect.top < (window.innerHeight || 800) + 240;
      if (near) init();
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;
          init();
          observer.disconnect();
        },
        { rootMargin: '320px 0px' }
      );
      observer.observe(root);
      boot();
      // Fallback if IO never fires (hash jump above/below)
      window.setTimeout(() => {
        if (!ready) init();
      }, 1200);
    } else {
      init();
    }
  })();
</script>

<style>
  .carousel-outer {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .carousel-outer--wide {
    gap: 1rem;
  }

  .carousel-wrap {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    direction: ltr;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: none;
    scroll-behavior: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-block: 0.25rem;
  }

  .carousel-outer--wide .carousel-track {
    gap: 1.5rem;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-track :global(.carousel-item) {
    flex: 0 0 auto;
  }

  .carousel-arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    min-width: 44px;
    min-height: 44px;
    border-radius: 50%;
    border: 2px solid #c60691;
    background: #fff;
    color: #651561;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, opacity 0.2s;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.08);
    z-index: 2;
  }

  .carousel-arrow:hover:not(:disabled) {
    background: #651561;
    color: #fff;
    border-color: #651561;
  }

  .carousel-arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .carousel-arrow:focus-visible {
    outline: 2px solid #fcc000;
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .carousel-outer {
      gap: 0;
    }

    .carousel-wrap {
      width: 100%;
    }

    .carousel-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 2.25rem;
      height: 2.25rem;
      min-width: 44px;
      min-height: 44px;
      background: rgb(255 255 255 / 0.96);
    }

    .carousel-arrow--edge-start {
      right: 0.15rem;
    }

    .carousel-arrow--edge-end {
      left: 0.15rem;
    }

    .carousel-track {
      padding-inline: 2.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-arrow {
      transition: none;
    }
  }
</style>
