---
import SectionTitle from './SectionTitle.astro';
import Reveal from './Reveal.astro';
import YoutubeFacade from './YoutubeFacade.astro';
import { videoTestimonials } from '../data/site';
---

<section id="video-testimonials" class="section-padding below-fold bg-white" aria-labelledby="video-testimonials-title">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <Reveal>
      <SectionTitle title="עדויות וידאו" id="video-testimonials-title" class="mb-10 md:mb-14" />
    </Reveal>

    <Reveal delay={120}>
      <div class="flex flex-col items-center justify-center gap-12 md:flex-row md:gap-16 lg:gap-24">
        {
          videoTestimonials.map((video) => (
            <figure class="video-card w-[220px] shrink-0 sm:w-[240px] md:w-[260px]">
              <YoutubeFacade youtubeId={video.youtubeId} title={video.title} />
              <figcaption class="mt-3 text-center text-sm font-medium text-gray-600">{video.title}</figcaption>
            </figure>
          ))
        }
      </div>
    </Reveal>
  </div>
</section>

<script>
  document.querySelectorAll('.youtube-facade__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const button = btn as HTMLButtonElement;
      const id = button.dataset.youtubeId;
      const title = button.dataset.youtubeTitle || 'YouTube video';
      if (!id) return;

      const wrapper = button.parentElement;
      if (!wrapper) return;

      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
      iframe.title = title;
      iframe.className = 'absolute inset-0 h-full w-full';
      iframe.loading = 'lazy';
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;

      wrapper.innerHTML = '';
      wrapper.appendChild(iframe);
    });
  });
</script>
