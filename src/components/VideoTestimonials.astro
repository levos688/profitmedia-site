---
import SectionTitle from './SectionTitle.astro';
import Reveal from './Reveal.astro';
import { videoTestimonials } from '../data/site';
---

<section id="video-testimonials" class="section-padding bg-white" aria-labelledby="video-testimonials-title">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <Reveal>
      <SectionTitle title="עדויות וידאו" id="video-testimonials-title" class="mb-10 md:mb-14" />
    </Reveal>

    <Reveal delay={120}>
      <div class="flex flex-col items-center justify-center gap-12 md:flex-row md:gap-16 lg:gap-24">
      {
        videoTestimonials.map((video) => (
          <figure class="video-card w-[220px] shrink-0 sm:w-[240px] md:w-[260px]">
            <div class="overflow-hidden rounded-xl bg-black shadow-lg">
              <div class="relative aspect-[9/16] w-full">
                <iframe
                  src={`https://www.youtube.com/embed/${video.youtubeId}`}
                  title={video.title}
                  class="absolute inset-0 h-full w-full"
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
            </div>
            <figcaption class="mt-3 text-center text-sm font-medium text-gray-600">{video.title}</figcaption>
          </figure>
        ))
      }
      </div>
    </Reveal>
  </div>
</section>
