---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="blog-faq__list">
  {
    items.map((item) => (
      <details class="blog-faq__item">
        <summary>
          <span>{item.question}</span>
          <span class="blog-faq__icon" aria-hidden="true" />
        </summary>
        <div class="blog-faq__answer">
          <p>{item.answer}</p>
        </div>
      </details>
    ))
  }
</div>

<style>
  .blog-faq__list {
    display: grid;
    gap: 0.75rem;
  }

  .blog-faq__item {
    overflow: hidden;
    border: 1px solid rgba(101, 21, 97, 0.12);
    border-radius: 4px;
    background: #fff;
    box-shadow: 0 5px 20px rgba(101, 21, 97, 0.05);
  }

  .blog-faq__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: 4rem;
    padding: 1.05rem 1.25rem;
    cursor: pointer;
    list-style: none;
    color: #29102c;
    font-size: 1.0625rem;
    line-height: 1.45;
    font-weight: 800;
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .blog-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .blog-faq__item summary:hover {
    background: rgba(101, 21, 97, 0.035);
    color: #651561;
  }

  .blog-faq__item summary:focus-visible {
    outline: 3px solid #fcc000;
    outline-offset: -3px;
  }

  .blog-faq__icon {
    position: relative;
    flex: 0 0 2.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(101, 21, 97, 0.08);
  }

  .blog-faq__icon::before,
  .blog-faq__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0.9rem;
    height: 2px;
    border-radius: 999px;
    background: #651561;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease;
  }

  .blog-faq__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .blog-faq__item[open] .blog-faq__icon {
    background: #fcc000;
  }

  .blog-faq__item[open] .blog-faq__icon::after {
    transform: translate(-50%, -50%) rotate(0);
  }

  .blog-faq__answer {
    padding: 0 1.25rem 1.25rem;
  }

  .blog-faq__answer p {
    margin: 0;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(101, 21, 97, 0.09);
    color: #4b5563;
    font-size: 0.975rem;
    line-height: 1.75;
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-faq__item summary,
    .blog-faq__icon::before,
    .blog-faq__icon::after {
      transition: none;
    }
  }
</style>
