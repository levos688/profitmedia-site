---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  preloadImage?: string | false;
  metaPixelId?: string;
  metaPixelLead?: boolean;
}

const {
  title = 'פרסום באינטרנט | פרסום שמביא רווחים | Profit Media',
  description = 'פרסום באינטרנט | פרסום בגוגל | פרסום בפייסבוק | פרסום באינסטגרם | הקמה דפי נחיתה',
  noindex = false,
  preloadImage = '/images/hero/photo-min.svg',
  metaPixelId,
  metaPixelLead = false,
} = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {
      noindex && (
        <>
          <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex" />
          <meta name="googlebot" content="noindex, nofollow" />
        </>
      )
    }
    <link rel="icon" href="/favicon.ico?v=3" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/site-icon.png?v=3" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png?v=3" />
    <meta name="theme-color" content="#651561" />
    {
      preloadImage && (
        <link
          rel="preload"
          href={preloadImage}
          as="image"
          type={preloadImage.endsWith('.webp') ? 'image/webp' : 'image/svg+xml'}
          fetchpriority="high"
        />
      )
    }
    <link
      rel="preload"
      href="/fonts/assistant-hebrew-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/assistant-hebrew-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    {
      metaPixelId && (
        <>
          <script is:inline define:vars={{ metaPixelId, metaPixelLead }}>
            !(function (f, b, e, v, n, t, s) {
              if (f.fbq) return;
              n = f.fbq = function () {
                n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
              };
              if (!f._fbq) f._fbq = n;
              n.push = n;
              n.loaded = !0;
              n.version = '2.0';
              n.queue = [];
              t = b.createElement(e);
              t.async = !0;
              t.src = v;
              s = b.getElementsByTagName(e)[0];
              s.parentNode.insertBefore(t, s);
            })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', metaPixelId);
            fbq('track', 'PageView');
            if (metaPixelLead) fbq('track', 'Lead');
          </script>
          <noscript>
            <img
              height="1"
              width="1"
              style="display:none"
              src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
              alt=""
            />
          </noscript>
        </>
      )
    }
    <!-- Google Tag Manager: loads on user interaction only (keeps PageSpeed clean) -->
    <script is:inline>
      (function () {
        var loaded = false;
        function loadGtm() {
          if (loaded) return;
          loaded = true;
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', 'GTM-57J48TC');
        }
        ['pointerdown', 'keydown'].forEach(function (type) {
          window.addEventListener(type, loadGtm, { once: true, passive: true });
        });
        setTimeout(loadGtm, 20000);
      })();
    </script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-57J48TC"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main-content" class="skip-link">דילוג לתוכן</a>
    <slot />
    <script is:inline>
      (function () {
        var loaded = false;
        function loadA11y() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.src = 'https://profitmedia.co.il/a11y/v1/profitmedia.js?v=3.7.1';
          s.defer = true;
          document.body.appendChild(s);
        }
        ['pointerdown', 'keydown'].forEach(function (type) {
          window.addEventListener(type, loadA11y, { once: true, passive: true });
        });
        setTimeout(loadA11y, 8000);
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          if (!sessionStorage.getItem('pm_first_landing')) {
            sessionStorage.setItem('pm_first_landing', location.href);
            var params = new URL(location.href).searchParams;
            var utm = {};
            ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'].forEach(
              function (key) {
                var value = params.get(key);
                if (value) utm[key] = value;
              }
            );
            if (Object.keys(utm).length) {
              sessionStorage.setItem('pm_first_utm', JSON.stringify(utm));
            }
          }
        } catch (e) {}

        function initReveal() {
          var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var revealEls = document.querySelectorAll('[data-reveal]');

          if (!revealEls.length) return;

          if (reduceMotion) {
            revealEls.forEach(function (el) {
              el.classList.add('is-visible');
            });
            return;
          }

          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.08, rootMargin: '0px 0px -8% 0px' }
          );

          revealEls.forEach(function (el) {
            observer.observe(el);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initReveal);
        } else {
          initReveal();
        }
      })();
    </script>
  </body>
</html>
