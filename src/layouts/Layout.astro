---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  blockAiCrawlers?: boolean;
  preloadImage?: string | false;
  enableGtm?: boolean;
  metaPixelId?: string;
  metaPixelLead?: boolean;
  lang?: string;
  dir?: 'ltr' | 'rtl';
}

const {
  title = 'פרסום באינטרנט | פרסום שמביא רווחים | Profit Media',
  description = 'פרסום באינטרנט | פרסום בגוגל | פרסום בפייסבוק | פרסום באינסטגרם | הקמה דפי נחיתה',
  canonical,
  ogImage = 'https://profitmedia.co.il/icons/site-icon.png',
  noindex = false,
  blockAiCrawlers = false,
  preloadImage = '/images/hero/photo-min.svg',
  enableGtm = false,
  metaPixelId,
  metaPixelLead = false,
  lang = 'he',
  dir = 'rtl',
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM site context" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:site_name" content="Profit Media" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      noindex && (
        <>
          <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, max-image-preview:none, max-snippet:0" />
          <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet" />
          <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet" />
        </>
      )
    }
    {
      blockAiCrawlers && (
        <>
          <meta name="GPTBot" content="noindex, nofollow" />
          <meta name="ChatGPT-User" content="noindex, nofollow" />
          <meta name="CCBot" content="noindex, nofollow" />
          <meta name="anthropic-ai" content="noindex, nofollow" />
          <meta name="ClaudeBot" content="noindex, nofollow" />
          <meta name="Claude-Web" content="noindex, nofollow" />
          <meta name="Google-Extended" content="noindex, nofollow" />
          <meta name="PerplexityBot" content="noindex, nofollow" />
          <meta name="Applebot-Extended" content="noindex, nofollow" />
          <meta name="Bytespider" content="noindex, nofollow" />
          <meta name="Amazonbot" content="noindex, nofollow" />
          <meta name="cohere-ai" content="noindex, nofollow" />
          <meta name="Diffbot" content="noindex, nofollow" />
        </>
      )
    }
    <link rel="icon" href="/favicon.ico?v=3" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/site-icon.png?v=3" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png?v=3" />
    <meta name="theme-color" content="#651561" />
    {
      preloadImage && (
        <link
          rel="preload"
          href={preloadImage}
          as="image"
          type={preloadImage.endsWith('.webp') ? 'image/webp' : 'image/svg+xml'}
          fetchpriority="high"
        />
      )
    }
    <link
      rel="preload"
      href="/fonts/assistant-hebrew-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:inline id="pm-a11y-site-offset">
      #pm-a11y-widget-root .pm-fab {
        top: 50% !important;
        bottom: auto !important;
        left: 12px !important;
        right: auto !important;
        transform: translateY(-50%) !important;
      }
      #pm-a11y-widget-root .pm-panel {
        top: 50% !important;
        bottom: auto !important;
        left: 12px !important;
        right: auto !important;
        transform: translateY(-50%) !important;
      }
      @media (max-width: 480px) {
        #pm-a11y-widget-root .pm-fab,
        #pm-a11y-widget-root .pm-panel {
          left: 8px !important;
        }
      }
    </style>
    <title>{title}</title>
    {
      enableGtm && (
        <script is:inline>
          (function (w, d, s, l, i) {
            var loaded = false;
            function loadGtm() {
              if (loaded) return;
              loaded = true;
              w[l] = w[l] || [];
              w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
              var f = d.getElementsByTagName(s)[0],
                j = d.createElement(s),
                dl = l != 'dataLayer' ? '&l=' + l : '';
              j.async = true;
              j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
              f.parentNode.insertBefore(j, f);
            }
            function scheduleGtm() {
              ['pointerdown', 'keydown', 'touchstart'].forEach(function (type) {
                w.addEventListener(type, loadGtm, { once: true, passive: true });
              });
            }
            scheduleGtm();
          })(window, document, 'script', 'dataLayer', 'GTM-57J48TC');
        </script>
      )
    }
    {
      metaPixelId && (
        <>
          <script is:inline define:vars={{ metaPixelId, metaPixelLead }}>
            (function (pixelId, fireLead) {
              var loaded = false;

              function readCookie(name) {
                var match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
                return match ? decodeURIComponent(match[1]) : '';
              }

              function sendCapi(event, eventId) {
                fetch('/api/meta-event', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    event: event,
                    eventId: eventId,
                    pageUrl: location.href,
                    tracking: { fbp: readCookie('_fbp'), fbc: readCookie('_fbc') },
                  }),
                }).catch(function () {});
              }

              function loadPixel() {
                if (loaded) return;
                loaded = true;

                !function (f, b, e, v, n, t, s) {
                  if (f.fbq) return;
                  n = f.fbq = function () {
                    n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
                  };
                  if (!f._fbq) f._fbq = n;
                  n.push = n;
                  n.loaded = !0;
                  n.version = '2.0';
                  n.queue = [];
                  t = b.createElement(e);
                  t.async = !0;
                  t.src = v;
                  s = b.getElementsByTagName(e)[0];
                  s.parentNode.insertBefore(t, s);
                }(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');

                fbq('init', pixelId);
                var pageViewEventId = '';
                try {
                  pageViewEventId = crypto.randomUUID();
                } catch (e) {
                  pageViewEventId = String(Date.now());
                }
                fbq('track', 'PageView', {}, { eventID: pageViewEventId });
                sendCapi('PageView', pageViewEventId);

                if (!fireLead) return;

                var leadEventId = '';
                try {
                  leadEventId = sessionStorage.getItem('donhin_lead_event_id') || '';
                  sessionStorage.removeItem('donhin_lead_event_id');
                } catch (e) {}
                if (leadEventId) {
                  fbq('track', 'Lead', {}, { eventID: leadEventId });
                } else {
                  fbq('track', 'Lead');
                }
              }

              loadPixel();
            })(metaPixelId, metaPixelLead);
          </script>
          <noscript>
            <img
              height="1"
              width="1"
              style="display:none"
              src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
              alt=""
            />
            {
              metaPixelLead && (
                <img
                  height="1"
                  width="1"
                  style="display:none"
                  src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=Lead&noscript=1`}
                  alt=""
                />
              )
            }
          </noscript>
        </>
      )
    }
    <slot name="head" />
  </head>
  <body class="bg-white text-gray-900 antialiased">
    {
      enableGtm && (
        <noscript>
          <iframe
            src="https://www.googletagmanager.com/ns.html?id=GTM-57J48TC"
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }
    <a href="#main-content" class="skip-link">דילוג לתוכן</a>
    <slot />
    <slot name="scripts" />
    <script is:inline>
      (function () {
        var loaded = false;
        var LOAD_DELAY_MS = 4000;

        function loadA11y() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.src = 'https://profitmedia.co.il/a11y/v1/profitmedia.js?v=3.7.1';
          s.defer = true;
          document.body.appendChild(s);
        }

        // Load shortly after first paint so LCP stays clean, without waiting for a click.
        if (document.readyState === 'complete') {
          window.setTimeout(loadA11y, LOAD_DELAY_MS);
        } else {
          window.addEventListener(
            'load',
            function () {
              window.setTimeout(loadA11y, LOAD_DELAY_MS);
            },
            { once: true }
          );
        }

        // If the user interacts earlier, bring the widget in immediately.
        ['pointerdown', 'keydown', 'touchstart'].forEach(function (type) {
          window.addEventListener(type, loadA11y, { once: true, passive: true });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        function positionA11yWidget() {
          var root = document.getElementById('pm-a11y-widget-root');
          if (!root) return false;
          var fab = root.querySelector('.pm-fab');
          var panel = root.querySelector('.pm-panel');
          [fab, panel].forEach(function (el) {
            if (!el) return;
            el.style.setProperty('top', '50%', 'important');
            el.style.setProperty('bottom', 'auto', 'important');
            el.style.setProperty('left', '12px', 'important');
            el.style.setProperty('right', 'auto', 'important');
            el.style.setProperty('transform', 'translateY(-50%)', 'important');
          });
          return true;
        }

        var ticks = 0;
        var timer = window.setInterval(function () {
          if (positionA11yWidget() || ticks >= 20) {
            // Keep correcting for a bit after mount in case the widget restyles itself.
            ticks += 1;
            if (ticks >= 20) window.clearInterval(timer);
          }
        }, 250);

        if (typeof MutationObserver !== 'undefined') {
          var observer = new MutationObserver(function () {
            if (positionA11yWidget()) observer.disconnect();
          });
          observer.observe(document.documentElement, { childList: true, subtree: true });
          window.setTimeout(function () {
            observer.disconnect();
          }, 15000);
        }
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          if (!sessionStorage.getItem('pm_first_landing')) {
            sessionStorage.setItem('pm_first_landing', location.href);
            var params = new URL(location.href).searchParams;
            var utm = {};
            ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'].forEach(
              function (key) {
                var value = params.get(key);
                if (value) utm[key] = value;
              }
            );
            if (Object.keys(utm).length) {
              sessionStorage.setItem('pm_first_utm', JSON.stringify(utm));
            }
          }
        } catch (e) {}

        function initReveal() {
          var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var revealEls = document.querySelectorAll('[data-reveal]');

          if (!revealEls.length) return;

          if (reduceMotion) {
            revealEls.forEach(function (el) {
              el.classList.add('is-visible');
            });
            return;
          }

          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              });
            },
            // Generous rootMargin so elements aren't blocked by sticky mobile CTA /
            // iOS Safari bottom chrome before they become visible.
            { threshold: 0.01, rootMargin: '0px 0px 20% 0px' }
          );

          revealEls.forEach(function (el) {
            var rect = el.getBoundingClientRect();
            var vh = window.innerHeight || document.documentElement.clientHeight;
            // Already on screen (or just below) — show immediately without waiting for IO.
            if (rect.top < vh * 1.05 && rect.bottom > 0) {
              el.classList.add('is-visible');
              return;
            }
            observer.observe(el);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initReveal);
        } else {
          initReveal();
        }
      })();
    </script>
  </body>
</html>
