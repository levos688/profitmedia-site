---
import Layout from './Layout.astro';
import DonhinFooter from '../components/donhin/DonhinFooter.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  metaPixelLead?: boolean;
}

const { title, description, lang = 'ru', dir = 'ltr', metaPixelLead = false } = Astro.props;

const META_PIXEL_ID = '2253228458374300';
---

<Layout
  title={title}
  description={description}
  preloadImage="/images/donhin/hero.webp"
  noindex
  enableGtm={false}
  metaPixelId={META_PIXEL_ID}
  metaPixelLead={metaPixelLead}
>
  <div class="landing-page" lang={lang} dir={dir}>
    <slot />
    <DonhinFooter />
  </div>
  <slot name="scripts" />
</Layout>

<style>
  .landing-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: Assistant, system-ui, -apple-system, 'Segoe UI', sans-serif;
  }

  .landing-page :global(main) {
    flex: 1;
  }
</style>
