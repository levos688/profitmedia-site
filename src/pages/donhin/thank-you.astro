---
import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Спасибо | Адвокат Саймон Донхин"
  description="Спасибо за обращение. Адвокат Саймон Донхин позвонит вам в ближайшее время."
  metaPixelPageView={false}
  metaPixelLead
>
  <main id="main-content" class="donhin-thanks">
    <div class="donhin-thanks__card">
      <img
        src="/images/donhin/hero.webp"
        alt="Адвокат Саймон Донхин"
        class="donhin-thanks__photo"
        width="280"
        height="373"
        loading="eager"
        decoding="async"
      />
      <div class="donhin-thanks__content">
        <h1 class="donhin-thanks__title">Спасибо за обращение.</h1>
        <p class="donhin-thanks__text">Адвокат Саймон Донхин позвонит вам в ближайшее время</p>
        <div class="donhin-thanks__bio">
          <h2>Адвокат Саймон Донхин</h2>
          <ul>
            <li>Опытный адвокат с более чем 15-летним стажем работы</li>
            <li>Первая степень по юриспруденции — Кирьят Оно</li>
            <li>Вторая степень по криминологии — Еврейский университет</li>
            <li>Специализация по медицинской халатности</li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</LandingLayout>

<style>
  .donhin-thanks {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem;
    background: #f5f5f5;
  }

  .donhin-thanks__card {
    width: min(100%, 56rem);
    display: grid;
    gap: 2rem;
    align-items: center;
    background: #fff;
    border-radius: 0.5rem;
    padding: 2rem;
    box-shadow: 0 8px 32px rgba(21, 71, 127, 0.08);
  }

  @media (min-width: 768px) {
    .donhin-thanks__card {
      grid-template-columns: auto 1fr;
      padding: 2.5rem 3rem;
      gap: 2.5rem;
    }
  }

  .donhin-thanks__photo {
    width: min(100%, 16rem);
    height: auto;
    border-radius: 0.25rem;
    display: block;
    margin-inline: auto;
  }

  .donhin-thanks__title {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #15477f;
    line-height: 1.2;
  }

  .donhin-thanks__text {
    margin: 1rem 0 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: #333;
    line-height: 1.45;
  }

  .donhin-thanks__bio {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e5e5;
  }

  .donhin-thanks__bio h2 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: #15477f;
  }

  .donhin-thanks__bio ul {
    margin: 0;
    padding-inline-start: 1.25rem;
    color: #15477f;
    font-size: 0.9375rem;
    line-height: 1.65;
    font-weight: 600;
  }
</style>
