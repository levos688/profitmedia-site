---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Donhin A/B Stats"
  description="Internal Donhin experiment dashboard"
  noindex
  blockAiCrawlers
  preloadImage={false}
  enableGtm={false}
  enableA11y={false}
  lang="ru"
  dir="ltr"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main id="main-content" class="ab-stats" dir="ltr" lang="ru">
    <div class="ab-stats__panel">
      <header class="ab-stats__header">
        <h1>Donhin A/B тесты</h1>
        <p class="ab-stats__subtitle">Внутренняя статистика экспериментов</p>
      </header>

      <div class="ab-stats__switcher">
        <p class="ab-stats__switcher-label">Источник данных</p>
        <div class="ab-stats__tabs" role="tablist" aria-label="Источник трафика">
          <button type="button" class="ab-stats__tab is-active" data-channel="fb_ads" role="tab" aria-selected="true">
            Только Facebook реклама
          </button>
          <button type="button" class="ab-stats__tab" data-channel="all" role="tab" aria-selected="false">
            Все визиты (включая тесты)
          </button>
        </div>
        <p id="ab-stats-channel-note" class="ab-stats__channel-note">
          Показана статистика только с переходов из Facebook Ads (fbclid, utm_source=ri_XX и т.п.).
        </p>
      </div>

      <p id="ab-stats-status" class="ab-stats__status">Загрузка…</p>
      <div id="ab-stats-root" class="ab-stats__root"></div>
      <p class="ab-stats__updated" id="ab-stats-updated"></p>
    </div>
  </main>
</Layout>

<script>
  type VariantRow = {
    variant: string;
    impression: number;
    click: number;
    conversion: number;
    ctr: number;
    cvr: number;
  };

  const params = new URLSearchParams(window.location.search);
  const token = params.get('token') || '';

  const statusEl = document.getElementById('ab-stats-status');
  const rootEl = document.getElementById('ab-stats-root');
  const updatedEl = document.getElementById('ab-stats-updated');
  const channelNoteEl = document.getElementById('ab-stats-channel-note');
  const tabButtons = Array.from(document.querySelectorAll('.ab-stats__tab'));

  const channelFromUrl = params.get('channel');
  let activeChannel = channelFromUrl === 'all' ? 'all' : 'fb_ads';
  let cachedData: {
    updatedAt?: string;
    channels?: Record<
      string,
      {
        label: string;
        experiments: Array<{
          experiment: string;
          variants: VariantRow[];
        }>;
      }
    >;
  } | null = null;

  const labels: Record<string, Record<string, string>> = {
    sticky_cta: {
      get_consult: 'Получить бесплатную консультацию',
      free_consult: 'Бесплатная консультация',
    },
    popup_delay: {
      '15s': '15 секунд',
      '18s': '18 секунд',
      '22s': '22 секунды',
      '25s': '25 секунд',
    },
    popup_scroll: {
      '80pct': 'Скролл 80%',
      '60pct': 'Скролл 60%',
      '50pct': 'Скролл 50%',
    },
    lead_source: {
      quiz: 'Квиз на странице',
      simple: 'Форма внизу страницы',
      popup_quiz: 'Popup с квизом',
      popup_simple: 'Popup со sticky-кнопки',
      hero_cta: 'Кнопка в шапке (hero)',
    },
  };

  const titles: Record<string, string> = {
    sticky_cta: 'Кнопка внизу экрана',
    popup_delay: 'Таймер popup',
    popup_scroll: 'Скролл popup',
    lead_source: 'Источник заявок и кликов',
  };

  /** Must match active variants in public/scripts/donhin-ab.js */
  const activeVariants: Record<string, string[]> = {
    sticky_cta: ['get_consult', 'free_consult'],
    popup_delay: ['22s', '25s'],
    popup_scroll: ['60pct', '50pct'],
    lead_source: ['quiz', 'simple', 'popup_quiz', 'popup_simple', 'hero_cta'],
  };

  const channelNotes: Record<string, string> = {
    fb_ads: 'Показана статистика только с переходов из Facebook Ads (fbclid, utm_source=ri_XX и т.п.).',
    all: 'Показана вся статистика, включая ваши тестовые визиты без рекламы.',
  };

  function isVariantActive(experiment: string, variant: string): boolean {
    const list = activeVariants[experiment];
    if (!list) return true;
    return list.includes(variant);
  }

  function scoreVariant(experiment: string, variant: VariantRow): number {
    if (experiment === 'lead_source') {
      return variant.conversion * 1000 + variant.click;
    }
    if (experiment === 'sticky_cta') {
      return variant.conversion * 1000 + variant.cvr * 10 + variant.ctr;
    }
    return variant.conversion * 1000 + variant.cvr;
  }

  function rankMap(experiment: string, variants: VariantRow[]): Map<string, 'win' | 'lose'> {
    const ranked = new Map<string, 'win' | 'lose'>();
    const eligible = variants.filter((v) => v.impression > 0 || v.click > 0 || v.conversion > 0);
    if (eligible.length < 2) return ranked;

    const scored = eligible.map((v) => ({ id: v.variant, score: scoreVariant(experiment, v) }));
    const max = Math.max(...scored.map((s) => s.score));
    const min = Math.min(...scored.map((s) => s.score));
    if (max === min) return ranked;

    scored.forEach((s) => {
      if (s.score === max) ranked.set(s.id, 'win');
      if (s.score === min && experiment !== 'lead_source') ranked.set(s.id, 'lose');
    });
    return ranked;
  }

  function sumVariants(variants: VariantRow[]) {
    const impression = variants.reduce((sum, v) => sum + v.impression, 0);
    const click = variants.reduce((sum, v) => sum + v.click, 0);
    const conversion = variants.reduce((sum, v) => sum + v.conversion, 0);
    const ctr = impression > 0 ? Number(((click / impression) * 100).toFixed(2)) : 0;
    const cvr = impression > 0 ? Number(((conversion / impression) * 100).toFixed(2)) : 0;
    return { impression, click, conversion, ctr, cvr };
  }

  function renderSummary(experiments: Array<{ experiment: string; variants: VariantRow[] }>) {
    const leadSource = experiments.find((item) => item.experiment === 'lead_source');
    const leadTotals = leadSource ? sumVariants(leadSource.variants) : null;
    const sticky = experiments.find((item) => item.experiment === 'sticky_cta');
    const stickyTotals = sticky ? sumVariants(sticky.variants) : null;
    const totalLeads = leadTotals
      ? leadSource!.variants
          .filter((v) => v.variant !== 'hero_cta')
          .reduce((sum, v) => sum + v.conversion, 0)
      : stickyTotals?.conversion || 0;
    const totalStickyClicks = stickyTotals?.click || 0;
    const totalHeroClicks = leadSource?.variants.find((v) => v.variant === 'hero_cta')?.click || 0;

    return `<section class="ab-stats__summary" aria-label="Сводка">
      <article class="ab-stats__summary-card">
        <p class="ab-stats__summary-label">Всего заявок</p>
        <p class="ab-stats__summary-value">${totalLeads}</p>
        <p class="ab-stats__summary-note">по всем формам</p>
      </article>
      <article class="ab-stats__summary-card">
        <p class="ab-stats__summary-label">Клики sticky</p>
        <p class="ab-stats__summary-value">${totalStickyClicks}</p>
        <p class="ab-stats__summary-note">кнопка внизу экрана</p>
      </article>
      <article class="ab-stats__summary-card">
        <p class="ab-stats__summary-label">Клики hero</p>
        <p class="ab-stats__summary-value">${totalHeroClicks}</p>
        <p class="ab-stats__summary-note">кнопка в шапке</p>
      </article>
      <article class="ab-stats__summary-card">
        <p class="ab-stats__summary-label">Показы sticky</p>
        <p class="ab-stats__summary-value">${stickyTotals?.impression || 0}</p>
        <p class="ab-stats__summary-note">сумма вариантов кнопки</p>
      </article>
    </section>`;
  }

  function setActiveChannel(channel: string) {
    activeChannel = channel === 'all' ? 'all' : 'fb_ads';
    tabButtons.forEach((tab) => {
      const isActive = tab.getAttribute('data-channel') === activeChannel;
      tab.classList.toggle('is-active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    if (channelNoteEl) channelNoteEl.textContent = channelNotes[activeChannel];

    const nextParams = new URLSearchParams(window.location.search);
    nextParams.set('channel', activeChannel);
    if (token) nextParams.set('token', token);
    const nextUrl = `${window.location.pathname}?${nextParams.toString()}`;
    window.history.replaceState(null, '', nextUrl);
  }

  function renderChannel() {
    if (!rootEl || !cachedData?.channels) return;

    const channel = cachedData.channels[activeChannel];
    if (!channel) {
      rootEl.innerHTML = '<p class="ab-stats__empty">Нет данных для выбранного источника.</p>';
      return;
    }

    const experimentOrder = ['lead_source', 'sticky_cta', 'popup_delay', 'popup_scroll'];
    const experiments = [...channel.experiments].sort((a, b) => {
      const ai = experimentOrder.indexOf(a.experiment);
      const bi = experimentOrder.indexOf(b.experiment);
      return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
    });

    const tables = experiments
      .map((experiment) => {
        const ranks = rankMap(experiment.experiment, experiment.variants);
        const totals = sumVariants(experiment.variants);
        const showLegend = experiment.experiment !== 'lead_source';
        const rows = experiment.variants
          .map((variant) => {
            const name = labels[experiment.experiment]?.[variant.variant] || variant.variant;
            const rank = ranks.get(variant.variant);
            const active = isVariantActive(experiment.experiment, variant.variant);
            const rowClass = [
              rank === 'win' ? 'is-win' : '',
              rank === 'lose' ? 'is-lose' : '',
              active ? 'is-active-variant' : 'is-inactive-variant',
            ]
              .filter(Boolean)
              .join(' ');
            const badge =
              rank === 'win'
                ? '<span class="ab-stats__badge ab-stats__badge--win">Лучший</span>'
                : rank === 'lose'
                  ? '<span class="ab-stats__badge ab-stats__badge--lose">Слабый</span>'
                  : '';
            const status = active
              ? `<span class="ab-stats__lamp ab-stats__lamp--on" title="Вариант включён в тест" aria-label="Включён"></span>`
              : `<span class="ab-stats__lamp ab-stats__lamp--off" title="Вариант выключен, данные только исторические" aria-label="Выключен"></span>`;

            return `<tr class="${rowClass}">
              <td class="ab-stats__variant">
                <span class="ab-stats__variant-main">
                  ${status}
                  <span class="ab-stats__variant-name">${name}</span>
                </span>
                ${badge}
              </td>
              <td class="ab-stats__num ab-stats__col--imp">${variant.impression}</td>
              <td class="ab-stats__num ab-stats__col--click">${variant.click}</td>
              <td class="ab-stats__num ab-stats__col--conv">${variant.conversion}</td>
              <td class="ab-stats__num ab-stats__col--ctr">${variant.ctr}%</td>
              <td class="ab-stats__num ab-stats__col--cvr">${variant.cvr}%</td>
            </tr>`;
          })
          .join('');

        return `<section class="ab-stats__block">
          <div class="ab-stats__block-head">
            <h2>${titles[experiment.experiment] || experiment.experiment}</h2>
            <p class="ab-stats__legend">
              <span class="ab-stats__legend-item ab-stats__legend-item--on">
                <span class="ab-stats__lamp ab-stats__lamp--on" aria-hidden="true"></span>
                Включён
              </span>
              <span class="ab-stats__legend-item ab-stats__legend-item--off">
                <span class="ab-stats__lamp ab-stats__lamp--off" aria-hidden="true"></span>
                Выключен
              </span>
              ${
                showLegend
                  ? `<span class="ab-stats__legend-item ab-stats__legend-item--win">Лучший</span>
              <span class="ab-stats__legend-item ab-stats__legend-item--lose">Слабый</span>`
                  : ''
              }
            </p>
          </div>
          <div class="ab-stats__table-wrap">
            <table class="ab-stats__table">
              <thead>
                <tr>
                  <th scope="col">Вариант</th>
                  <th scope="col" class="ab-stats__col--imp">Показы</th>
                  <th scope="col" class="ab-stats__col--click">Клики</th>
                  <th scope="col" class="ab-stats__col--conv">Конверсии</th>
                  <th scope="col" class="ab-stats__col--ctr">CTR</th>
                  <th scope="col" class="ab-stats__col--cvr">CVR</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
              <tfoot>
                <tr class="ab-stats__total-row">
                  <th scope="row">Итого</th>
                  <td class="ab-stats__num ab-stats__col--imp">${totals.impression}</td>
                  <td class="ab-stats__num ab-stats__col--click">${totals.click}</td>
                  <td class="ab-stats__num ab-stats__col--conv">${totals.conversion}</td>
                  <td class="ab-stats__num ab-stats__col--ctr">${totals.ctr}%</td>
                  <td class="ab-stats__num ab-stats__col--cvr">${totals.cvr}%</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </section>`;
      })
      .join('');

    rootEl.innerHTML = `${renderSummary(experiments)}${tables}`;
  }

  async function loadStats() {
    try {
      const query = token ? `?token=${encodeURIComponent(token)}` : '';
      const res = await fetch(`/api/ab-stats${query}`, { credentials: 'same-origin' });
      const data = (await res.json()) as {
        ok?: boolean;
        updatedAt?: string;
        channels?: typeof cachedData extends null ? never : NonNullable<typeof cachedData>['channels'];
        error?: string;
      };

      if (!res.ok || !data.ok || !data.channels) {
        if (statusEl) statusEl.textContent = data.error || 'Не удалось загрузить статистику';
        return;
      }

      cachedData = data;
      if (statusEl) statusEl.textContent = '';
      if (updatedEl && data.updatedAt) {
        updatedEl.textContent = `Обновлено: ${new Date(data.updatedAt).toLocaleString('ru-RU')}`;
      }

      renderChannel();
    } catch {
      if (statusEl) statusEl.textContent = 'Ошибка загрузки статистики';
    }
  }

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      setActiveChannel(button.getAttribute('data-channel') || 'fb_ads');
      renderChannel();
    });
  });

  setActiveChannel(activeChannel);
  loadStats();
  window.setInterval(loadStats, 30000);
</script>

<style is:global>
  .ab-stats {
    --ab-ink: #16324f;
    --ab-muted: #5b6b7c;
    --ab-line: #d7e0ea;
    --ab-panel: #ffffff;
    --ab-soft: #f3f6fa;
    --ab-accent: #1f4e79;
    --ab-win-bg: #eef8f1;
    --ab-win-border: #b7dcc3;
    --ab-win-text: #1f6b3a;
    --ab-lose-bg: #fbf1f1;
    --ab-lose-border: #e4bcbc;
    --ab-lose-text: #8f3d3d;
    --ab-col-imp: #f4f8fc;
    --ab-col-click: #f7f5f2;
    --ab-col-conv: #f3f7f4;
    --ab-col-ctr: #f6f4f9;
    --ab-col-cvr: #f2f6fb;

    min-height: 100dvh;
    direction: ltr;
    text-align: left;
    padding: 2.5rem 1.25rem 4.5rem;
    background:
      radial-gradient(ellipse 80% 50% at 10% -10%, rgba(31, 78, 121, 0.08), transparent 55%),
      radial-gradient(ellipse 60% 40% at 90% 0%, rgba(120, 150, 170, 0.1), transparent 50%),
      #e8eef4;
    font-family: Outfit, Assistant, system-ui, -apple-system, 'Segoe UI', sans-serif;
    color: var(--ab-ink);
  }

  .ab-stats__panel {
    width: min(100%, 74rem);
    margin-inline: auto;
    background: var(--ab-panel);
    border: 1px solid rgba(22, 50, 79, 0.08);
    border-radius: 1.125rem;
    padding: 2rem 1.75rem 2.35rem;
    box-shadow: 0 18px 48px rgba(22, 50, 79, 0.08);
  }

  .ab-stats__header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--ab-line);
  }

  .ab-stats h1 {
    margin: 0 0 0.45rem;
    color: var(--ab-accent);
    font-size: clamp(1.55rem, 2.8vw, 1.95rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    text-wrap: balance;
  }

  .ab-stats__subtitle {
    margin: 0;
    color: var(--ab-muted);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.55;
  }

  .ab-stats__switcher {
    margin-bottom: 2rem;
    padding: 1.35rem 1.5rem;
    border: 1px solid var(--ab-line);
    border-radius: 0.875rem;
    background: linear-gradient(180deg, #f8fafc 0%, #f3f6fa 100%);
  }

  .ab-stats__switcher-label {
    margin: 0 0 0.85rem;
    color: var(--ab-accent);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ab-stats__tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }

  .ab-stats__tab {
    border: 1.5px solid #c8d4e2;
    border-radius: 0.7rem;
    background: #fff;
    color: #334155;
    padding: 0.9rem 1.05rem;
    font: inherit;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    text-align: left;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.15s ease;
  }

  .ab-stats__tab:hover {
    border-color: var(--ab-accent);
    color: var(--ab-accent);
  }

  .ab-stats__tab:active {
    transform: translateY(1px);
  }

  .ab-stats__tab:focus-visible {
    outline: 2px solid var(--ab-accent);
    outline-offset: 2px;
  }

  .ab-stats__tab.is-active {
    border-color: var(--ab-accent);
    background: var(--ab-accent);
    color: #fff;
    box-shadow: 0 6px 18px rgba(31, 78, 121, 0.22);
  }

  .ab-stats__channel-note,
  .ab-stats__status,
  .ab-stats__updated,
  .ab-stats__empty {
    margin: 0;
    color: var(--ab-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .ab-stats__updated {
    margin-top: 1.75rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--ab-line);
  }

  .ab-stats__root {
    display: grid;
    gap: 1.75rem;
  }

  .ab-stats__summary {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .ab-stats__summary-card {
    padding: 1rem 1.1rem;
    border: 1px solid var(--ab-line);
    border-radius: 0.85rem;
    background: linear-gradient(180deg, #f8fafc 0%, #f3f6fa 100%);
  }

  .ab-stats__summary-label {
    margin: 0;
    color: var(--ab-muted);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ab-stats__summary-value {
    margin: 0.35rem 0 0.15rem;
    color: var(--ab-accent);
    font-size: 1.65rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .ab-stats__summary-note {
    margin: 0;
    color: #7b8a9a;
    font-size: 0.75rem;
    line-height: 1.4;
  }

  .ab-stats__legend-note {
    margin: 0;
    color: var(--ab-muted);
    font-size: 0.78rem;
  }

  .ab-stats__total-row th,
  .ab-stats__total-row td {
    background: #e8eef5 !important;
    border-top: 1.5px solid #c5d2e0;
    font-weight: 700;
    color: var(--ab-ink);
  }

  .ab-stats__total-row th {
    text-align: left;
  }

  .ab-stats__block {
    padding: 1.35rem 1.35rem 1.5rem;
    border: 1px solid var(--ab-line);
    border-radius: 0.95rem;
    background: #fff;
  }

  .ab-stats__block-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.25rem;
    margin-bottom: 1rem;
  }

  .ab-stats__block h2 {
    margin: 0;
    color: var(--ab-accent);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.3;
  }

  .ab-stats__legend {
    display: inline-flex;
    gap: 0.55rem;
    margin: 0;
  }

  .ab-stats__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .ab-stats__legend-item--win {
    background: var(--ab-win-bg);
    color: var(--ab-win-text);
    border: 1px solid var(--ab-win-border);
  }

  .ab-stats__legend-item--lose {
    background: var(--ab-lose-bg);
    color: var(--ab-lose-text);
    border: 1px solid var(--ab-lose-border);
  }

  .ab-stats__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--ab-line);
    border-radius: 0.75rem;
    background: #fff;
  }

  .ab-stats__table {
    width: 100%;
    min-width: 52rem;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.9375rem;
    background: #fff;
  }

  .ab-stats__table th,
  .ab-stats__table td {
    padding: 0.95rem 1.15rem;
    vertical-align: middle;
    border-bottom: 1px solid var(--ab-line);
    border-right: 1px solid rgba(215, 224, 234, 0.9);
    line-height: 1.45;
  }

  .ab-stats__table th:last-child,
  .ab-stats__table td:last-child {
    border-right: none;
  }

  .ab-stats__table tbody tr:last-child td {
    border-bottom: none;
  }

  .ab-stats__table thead th {
