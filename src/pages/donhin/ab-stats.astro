---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Donhin A/B Stats"
  description="Internal Donhin experiment dashboard"
  noindex
  blockAiCrawlers
  preloadImage={false}
  enableGtm={false}
  lang="ru"
  dir="ltr"
>
  <main id="main-content" class="ab-stats" dir="ltr" lang="ru">
    <div class="ab-stats__panel">
      <header class="ab-stats__header">
        <h1>Donhin A/B тесты</h1>
        <p class="ab-stats__subtitle">Внутренняя статистика экспериментов</p>
      </header>

      <div class="ab-stats__switcher">
        <p class="ab-stats__switcher-label">Источник данных</p>
        <div class="ab-stats__tabs" role="tablist" aria-label="Источник трафика">
          <button type="button" class="ab-stats__tab is-active" data-channel="fb_ads" role="tab" aria-selected="true">
            Только Facebook реклама
          </button>
          <button type="button" class="ab-stats__tab" data-channel="all" role="tab" aria-selected="false">
            Все визиты (включая тесты)
          </button>
        </div>
        <p id="ab-stats-channel-note" class="ab-stats__channel-note">
          Показана статистика только с переходов из Facebook Ads (fbclid, utm_source=ri_XX и т.п.).
        </p>
      </div>

      <p id="ab-stats-status" class="ab-stats__status">Загрузка…</p>
      <div id="ab-stats-root" class="ab-stats__root"></div>
      <p class="ab-stats__updated" id="ab-stats-updated"></p>
    </div>
  </main>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token') || '';

  const statusEl = document.getElementById('ab-stats-status');
  const rootEl = document.getElementById('ab-stats-root');
  const updatedEl = document.getElementById('ab-stats-updated');
  const channelNoteEl = document.getElementById('ab-stats-channel-note');
  const tabButtons = Array.from(document.querySelectorAll('.ab-stats__tab'));

  const channelFromUrl = params.get('channel');
  let activeChannel = channelFromUrl === 'all' ? 'all' : 'fb_ads';
  let cachedData: {
    updatedAt?: string;
    channels?: Record<
      string,
      {
        label: string;
        experiments: Array<{
          experiment: string;
          variants: Array<{
            variant: string;
            impression: number;
            click: number;
            conversion: number;
            ctr: number;
            cvr: number;
          }>;
        }>;
      }
    >;
  } | null = null;

  const labels: Record<string, Record<string, string>> = {
    sticky_cta: {
      get_consult: 'Получить бесплатную консультацию',
      free_consult: 'Бесплатная консультация',
    },
    popup_delay: {
      '15s': '15 секунд',
      '18s': '18 секунд',
      '22s': '22 секунды',
    },
    popup_scroll: {
      '80pct': 'Скролл 80%',
      '60pct': 'Скролл 60%',
    },
  };

  const titles: Record<string, string> = {
    sticky_cta: 'Кнопка внизу экрана',
    popup_delay: 'Таймер popup',
    popup_scroll: 'Скролл popup',
  };

  const channelNotes: Record<string, string> = {
    fb_ads: 'Показана статистика только с переходов из Facebook Ads (fbclid, utm_source=ri_XX и т.п.).',
    all: 'Показана вся статистика, включая ваши тестовые визиты без рекламы.',
  };

  function setActiveChannel(channel: string) {
    activeChannel = channel === 'all' ? 'all' : 'fb_ads';
    tabButtons.forEach((tab) => {
      const isActive = tab.getAttribute('data-channel') === activeChannel;
      tab.classList.toggle('is-active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    if (channelNoteEl) channelNoteEl.textContent = channelNotes[activeChannel];

    const nextParams = new URLSearchParams(window.location.search);
    nextParams.set('channel', activeChannel);
    if (token) nextParams.set('token', token);
    const nextUrl = `${window.location.pathname}?${nextParams.toString()}`;
    window.history.replaceState(null, '', nextUrl);
  }

  function renderChannel() {
    if (!rootEl || !cachedData?.channels) return;

    const channel = cachedData.channels[activeChannel];
    if (!channel) {
      rootEl.innerHTML = '<p class="ab-stats__empty">Нет данных для выбранного источника.</p>';
      return;
    }

    rootEl.innerHTML = channel.experiments
      .map((experiment) => {
        const rows = experiment.variants
          .map((variant) => {
            const name = labels[experiment.experiment]?.[variant.variant] || variant.variant;
            return `<tr>
              <td class="ab-stats__variant">${name}</td>
              <td class="ab-stats__num">${variant.impression}</td>
              <td class="ab-stats__num">${variant.click}</td>
              <td class="ab-stats__num">${variant.conversion}</td>
              <td class="ab-stats__num">${variant.ctr}%</td>
              <td class="ab-stats__num">${variant.cvr}%</td>
            </tr>`;
          })
          .join('');

        return `<section class="ab-stats__block">
          <h2>${titles[experiment.experiment] || experiment.experiment}</h2>
          <div class="ab-stats__table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Вариант</th>
                  <th>Показы</th>
                  <th>Клики</th>
                  <th>Конверсии</th>
                  <th>CTR</th>
                  <th>CVR</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
        </section>`;
      })
      .join('');
  }

  async function loadStats() {
    try {
      const query = token ? `?token=${encodeURIComponent(token)}` : '';
      const res = await fetch(`/api/ab-stats${query}`, { credentials: 'same-origin' });
      const data = (await res.json()) as {
        ok?: boolean;
        updatedAt?: string;
        channels?: typeof cachedData extends null ? never : NonNullable<typeof cachedData>['channels'];
        error?: string;
      };

      if (!res.ok || !data.ok || !data.channels) {
        if (statusEl) statusEl.textContent = data.error || 'Не удалось загрузить статистику';
        return;
      }

      cachedData = data;
      if (statusEl) statusEl.textContent = '';
      if (updatedEl && data.updatedAt) {
        updatedEl.textContent = `Обновлено: ${new Date(data.updatedAt).toLocaleString('ru-RU')}`;
      }

      renderChannel();
    } catch {
      if (statusEl) statusEl.textContent = 'Ошибка загрузки статистики';
    }
  }

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      setActiveChannel(button.getAttribute('data-channel') || 'fb_ads');
      renderChannel();
    });
  });

  setActiveChannel(activeChannel);
  loadStats();
  window.setInterval(loadStats, 30000);
</script>

<style>
  .ab-stats {
    min-height: 100vh;
    direction: ltr;
    text-align: left;
    padding: 2.5rem 1.25rem 4.5rem;
    background: #eef2f7;
    font-family: Assistant, system-ui, -apple-system, 'Segoe UI', sans-serif;
  }

  .ab-stats__panel {
    width: min(100%, 72rem);
    margin-inline: auto;
    background: #fff;
    border-radius: 1rem;
    padding: 2rem 1.75rem 2.25rem;
    box-shadow: 0 12px 40px rgba(21, 71, 127, 0.1);
  }

  .ab-stats__header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .ab-stats h1 {
    margin: 0 0 0.5rem;
    color: #15477f;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    line-height: 1.25;
    text-align: left;
  }

  .ab-stats__subtitle {
    margin: 0;
    color: #6b7280;
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: 42rem;
  }

  .ab-stats__switcher {
    margin-bottom: 2rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid #d6e0ee;
    border-radius: 0.75rem;
    background: #f7f9fc;
  }

  .ab-stats__switcher-label {
    margin: 0 0 1rem;
    color: #15477f;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .ab-stats__tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.875rem;
    margin-bottom: 1rem;
  }

  .ab-stats__tab {
    border: 2px solid #c5d0df;
    border-radius: 0.625rem;
    background: #fff;
    color: #374151;
    padding: 0.9375rem 1.125rem;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.45;
    text-align: left;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
  }

  .ab-stats__tab:hover {
    border-color: #15477f;
    color: #15477f;
  }

  .ab-stats__tab:focus-visible {
    outline: 2px solid #15477f;
    outline-offset: 2px;
  }

  .ab-stats__tab.is-active {
    border-color: #15477f;
    background: #15477f;
    color: #fff;
    box-shadow: 0 4px 14px rgba(21, 71, 127, 0.22);
  }

  .ab-stats__channel-note {
    margin: 0;
    color: #4b5563;
    font-size: 0.875rem;
    line-height: 1.6;
    max-width: 48rem;
  }

  .ab-stats__status,
  .ab-stats__updated,
  .ab-stats__empty {
    color: #4b5563;
    font-size: 0.875rem;
    line-height: 1.55;
    text-align: left;
  }

  .ab-stats__updated {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e5e7eb;
  }

  .ab-stats__root {
    display: grid;
    gap: 2.25rem;
  }

  .ab-stats__block {
    padding: 1.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.75rem;
    background: #fff;
  }

  .ab-stats__block h2 {
    margin: 0 0 1.5rem;
    color: #15477f;
    font-size: 1.125rem;
    line-height: 1.35;
    text-align: left;
  }

  .ab-stats__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 0.5rem;
  }

  .ab-stats table {
    width: 100%;
    min-width: 42rem;
    border-collapse: separate;
    border-spacing: 0;
    border: 2px solid #9ca3af;
    border-radius: 0.5rem;
    overflow: hidden;
    font-size: 0.9375rem;
    background: #fff;
  }

  .ab-stats th,
  .ab-stats td {
    padding: 1.125rem 1.25rem;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid #cbd5e1;
    border-right: 1px solid #e2e8f0;
    line-height: 1.55;
  }

  .ab-stats th:last-child,
  .ab-stats td:last-child {
    border-right: none;
  }

  .ab-stats tbody tr:last-child td {
    border-bottom: none;
  }

  .ab-stats thead th {
    background: #e8eef5;
    color: #15477f;
    font-weight: 700;
    white-space: nowrap;
    border-bottom: 2px solid #9ca3af;
  }

  .ab-stats tbody tr:nth-child(even) td {
    background: #f8fafc;
  }

  .ab-stats tbody tr:hover td {
    background: #eef4fb;
  }

  .ab-stats__variant {
    min-width: 16rem;
    max-width: 26rem;
    white-space: normal;
    word-break: break-word;
    font-weight: 600;
    color: #1f2937;
    text-align: left;
  }

  .ab-stats__num {
    min-width: 6.5rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    color: #374151;
  }

  .ab-stats th:not(:first-child),
  .ab-stats td:not(:first-child) {
    text-align: right;
  }

  @media (max-width: 640px) {
    .ab-stats {
      padding: 1.5rem 1rem 3rem;
    }

    .ab-stats__panel {
      padding: 1.5rem 1.125rem 1.75rem;
    }

    .ab-stats__switcher {
      padding: 1.125rem 1.25rem;
    }

    .ab-stats__tabs {
      grid-template-columns: 1fr;
    }

    .ab-stats__block {
      padding: 1.25rem 1rem;
    }

    .ab-stats th,
    .ab-stats td {
      padding: 0.9375rem 0.875rem;
      font-size: 0.875rem;
    }

    .ab-stats__variant {
      min-width: 13rem;
    }
  }
</style>
