---
import LandingLayout from '../../layouts/LandingLayout.astro';

const benefits = [
  {
    icon: '/images/donhin/icon-consult.svg',
    title: 'Бесплатная консультация',
    text: 'Оценка перспектив дела и помощь в сборе документов.',
  },
  {
    icon: '/images/donhin/icon-payment.svg',
    title: 'Оплата по результатам — без риска',
    text: 'Платите только за результат, в котором вы уверены.',
  },
  {
    icon: '/images/donhin/icon-compensation.svg',
    title: 'Максимальная компенсация',
    text: 'Компенсация, которая покроет все расходы и моральный ущерб.',
  },
  {
    icon: '/images/donhin/icon-negotiation.svg',
    title: 'Ведение переговоров',
    text: 'Переговоры с врачом, больницей и страховой компанией.',
  },
];

const cases = [
  {
    amount: '280 тыс шекелей',
    image: '/images/donhin/case-magnets.svg',
    title: 'Ребенок проглотил магниты: история лечения и компенсации',
    text: 'Два с половиной года назад мальчик попал в больницу после того, как проглотил магнитные бусы. Несмотря на то, что бусы были видны на рентгене, персонал больницы решил не пытаться извлечь магниты. Магниты не вышли, и в итоге хирургам пришлось провести операцию. Впоследствии ребенку потребовалось еще два вмешательства. В рамках мирового соглашения больница выплатила семье мальчика 280 000 шекелей.',
  },
  {
    amount: '233 тыс шекелей',
    image: '/images/donhin/case-dental.svg',
    title: 'Стоматологическое протезирование с ошибками',
    text: 'Мужчина 50 лет обратился к врачу за стоматологическим протезированием. Изготовленные врачом съемные протезы не подошли пациенту. Врач предложил установить имплантаты и на них сделать постоянный протез. Врач имплантировал пациенту 12 имплантатов, но постоянный протез также не подошел. После многочисленных попыток исправить ситуацию, пациент подал в суд на врача. Суд вынес решение в пользу пациента и присудил ему компенсацию в размере 233 000 шекелей.',
  },
];
---

<LandingLayout
  title="Медицинская халатность в стоматологии | Адвокат Саймон Донхин"
  description="Получите положенную вам компенсацию за халатность стоматолога. Бесплатная консультация адвоката Саймона Донхина."
>
  <main id="main-content">
  <section class="donhin-hero">
    <div class="donhin-container donhin-hero__grid">
      <div class="donhin-hero__content">
        <h1 class="donhin-hero__title">
          Получите положенную вам компенсацию за халатность стоматолога
        </h1>
        <p class="donhin-hero__subtitle">
          За последние 15 лет мои клиенты получили более 20 миллионов шекелей
        </p>
        <a href="#form" class="donhin-btn donhin-btn--dark">Запишитесь на бесплатную консультацию</a>
      </div>
      <div class="donhin-hero__photo-wrap">
        <img
          src="/images/donhin/hero.webp"
          alt="Адвокат Саймон Донхин"
          class="donhin-hero__photo"
          width="397"
          height="530"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <p class="donhin-hero__name">Адвокат Саймон Донхин</p>
      </div>
    </div>
  </section>

  <section class="donhin-benefits">
    <div class="donhin-container">
      <h2 class="donhin-section-title">Почему стоит обратиться к адвокату Саймону?</h2>
      <div class="donhin-benefits__grid">
        {
          benefits.map((item) => (
            <article class="donhin-benefit">
              <img src={item.icon} alt="" width="80" height="80" class="donhin-benefit__icon" loading="lazy" decoding="async" />
              <h3 class="donhin-benefit__title">{item.title}</h3>
              <p class="donhin-benefit__text">{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="form" class="donhin-form-section">
    <div class="donhin-container donhin-form-section__inner">
      <h2 class="donhin-form-section__title">Пройдите быстрый тест и узнайте свои шансы</h2>

      <form class="donhin-form" id="donhin-form" novalidate>
        <div class="donhin-form__step" data-step="1">
          <fieldset class="donhin-quiz">
            <legend class="donhin-quiz__question">
              Оказывалась ли вам медицинская или стоматологическая помощь в последние 7 лет?
            </legend>
            <div class="donhin-quiz__options">
              <label class="donhin-radio">
                <input type="radio" name="quiz" value="Да" required />
                <span>Да</span>
              </label>
              <label class="donhin-radio">
                <input type="radio" name="quiz" value="Нет" />
                <span>Нет</span>
              </label>
            </div>
          </fieldset>
          <button type="button" class="donhin-btn donhin-btn--outline" id="donhin-next" disabled>
            Следующий
          </button>
        </div>

        <div class="donhin-form__step donhin-form__step--hidden" data-step="2" hidden>
          <h3 class="donhin-form__heading">Запишитесь на бесплатную консультацию</h3>
          <div class="donhin-fields">
            <label class="donhin-field">
              <span class="sr-only">Имя</span>
              <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
            </label>
            <label class="donhin-field">
              <span class="sr-only">Телефон</span>
              <input
                type="tel"
                name="phone"
                placeholder="Номер телефона"
                required
                autocomplete="tel"
                inputmode="tel"
                pattern="[0-9\-+() ]{9,15}"
              />
            </label>
          </div>

          <label class="donhin-privacy">
            <input type="checkbox" name="privacy" required />
            <span>
              Я ознакомлен(а) с{' '}
              <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
              {' '}и согласен(а) на обработку моих данных для связи по моему обращению (обязательно)
            </span>
          </label>
          <p id="donhin-privacy-error" class="donhin-error hidden" role="alert"></p>

          <button type="submit" class="donhin-btn donhin-btn--primary" id="donhin-submit">Отправить</button>
          <p id="donhin-status" class="donhin-status hidden" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </section>

  <section class="donhin-cases">
    <div class="donhin-container">
      <h2 class="donhin-section-title donhin-section-title--light">Примеры кейсов</h2>
      <div class="donhin-cases__grid">
        {
          cases.map((item) => (
            <article class="donhin-case">
              <div class="donhin-case__badge">Компенсация {item.amount}</div>
              <img src={item.image} alt="" class="donhin-case__img" width="560" height="320" loading="lazy" decoding="async" />
              <h3 class="donhin-case__title">{item.title}</h3>
              <p class="donhin-case__text">{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="donhin-about">
    <div class="donhin-container donhin-about__grid">
      <img
        src="/images/donhin/hero.webp"
        alt="Адвокат Саймон Донхин"
        class="donhin-about__photo"
        width="280"
        height="373"
        loading="lazy"
        decoding="async"
      />
      <div class="donhin-about__content">
        <h2 class="donhin-about__title">Адвокат Саймон Донхин</h2>
        <ul class="donhin-about__list">
          <li>Опытный адвокат с более чем 15-летним стажем работы</li>
          <li>Первая степень по юриспруденции — Кирьят Оно</li>
          <li>Вторая степень по криминологии — Еврейский университет</li>
          <li>Специализация по медицинской халатности</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="donhin-cta">
    <div class="donhin-container">
      <h2 class="donhin-cta__title">Оставьте заявку для бесплатной консультации</h2>
      <a href="#form" class="donhin-btn donhin-btn--dark">Отправить</a>
    </div>
  </section>
  </main>
</LandingLayout>

<script>
  const form = document.getElementById('donhin-form') as HTMLFormElement | null;
  const step1 = form?.querySelector('[data-step="1"]') as HTMLElement | null;
  const step2 = form?.querySelector('[data-step="2"]') as HTMLElement | null;
  const nextBtn = document.getElementById('donhin-next') as HTMLButtonElement | null;
  const submitBtn = document.getElementById('donhin-submit') as HTMLButtonElement | null;
  const status = document.getElementById('donhin-status');
  const privacyError = document.getElementById('donhin-privacy-error');
  const quizInputs = form?.querySelectorAll<HTMLInputElement>('input[name="quiz"]');

  quizInputs?.forEach((input) => {
    input.addEventListener('change', () => {
      if (nextBtn) nextBtn.disabled = !form?.querySelector('input[name="quiz"]:checked');
    });
  });

  nextBtn?.addEventListener('click', () => {
    if (!form?.querySelector('input[name="quiz"]:checked')) return;
    step1?.classList.add('donhin-form__step--hidden');
    step1?.setAttribute('hidden', '');
    step2?.classList.remove('donhin-form__step--hidden');
    step2?.removeAttribute('hidden');
    (form?.querySelector('input[name="name"]') as HTMLInputElement | null)?.focus();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status?.classList.add('hidden');
    privacyError?.classList.add('hidden');

    const nameInput = form.querySelector('input[name="name"]') as HTMLInputElement;
    const phoneInput = form.querySelector('input[name="phone"]') as HTMLInputElement;
    const privacyInput = form.querySelector('input[name="privacy"]') as HTMLInputElement;
    const quizInput = form.querySelector('input[name="quiz"]:checked') as HTMLInputElement | null;

    if (!privacyInput.checked) {
      if (privacyError) {
        privacyError.textContent = 'Необходимо согласие с политикой конфиденциальности';
        privacyError.classList.remove('hidden');
      }
      return;
    }

    const name = nameInput.value.trim();
    const phone = phoneInput.value.trim();
    if (!name || name.length < 2 || !phone || !/^[0-9\-+() ]{9,15}$/.test(phone)) return;

    if (submitBtn) submitBtn.disabled = true;
    if (submitBtn) submitBtn.textContent = 'Отправка…';

    const pageUrl = new URL(window.location.href);
    const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'] as const;
    const utm: Record<string, string> = {};
    utmKeys.forEach((key) => {
      const value = pageUrl.searchParams.get(key);
      if (value) utm[key] = value;
    });

    let landingUrl = window.location.href;
    try {
      landingUrl = sessionStorage.getItem('pm_first_landing') || window.location.href;
    } catch {
      /* ignore */
    }

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          phone,
          client: 'donhin',
          quizAnswer: quizInput?.value || '',
          pageUrl: window.location.href,
          landingUrl,
          referrer: document.referrer || '',
          utm,
          language: navigator.language || 'ru',
        }),
      });

      const data = (await res.json()) as { ok?: boolean };
      if (!res.ok || !data.ok) throw new Error('submit failed');

      window.location.href = '/donhin/thank-you';
    } catch {
      if (status) {
        status.textContent = 'Ошибка отправки. Попробуйте ещё раз или позвоните нам.';
        status.classList.remove('hidden');
        status.setAttribute('role', 'alert');
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Отправить';
      }
    }
  });
</script>

<style>
  .donhin-container {
    width: min(100% - 2rem, 72rem);
    margin-inline: auto;
  }

  .donhin-hero {
    background: #15477f;
    color: #fff;
    padding: 2.5rem 0 3rem;
  }

  .donhin-hero__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .donhin-hero {
      padding: 3.5rem 0 4rem;
    }

    .donhin-hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .donhin-hero__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.15;
    font-weight: 700;
    margin: 0;
  }

  .donhin-hero__subtitle {
    margin: 1.25rem 0 0;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    line-height: 1.4;
    font-weight: 600;
  }

  .donhin-hero__photo-wrap {
    text-align: center;
  }

  .donhin-hero__photo {
    width: min(100%, 24rem);
    height: auto;
    border-radius: 0.25rem;
    display: block;
    margin-inline: auto;
  }

  .donhin-hero__name {
    margin: 1rem 0 0;
    font-size: 1.125rem;
    font-weight: 700;
  }

  .donhin-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .donhin-btn:hover {
    transform: translateY(-1px);
  }

  .donhin-btn:focus-visible {
    outline: 2px solid #5257de;
    outline-offset: 3px;
  }

  .donhin-btn--dark {
    background: #000;
    color: #fff;
    margin-top: 1.75rem;
  }

  .donhin-btn--primary {
    background: #5257de;
    color: #fff;
    width: 100%;
    margin-top: 1.25rem;
  }

  .donhin-btn--outline {
    background: transparent;
    color: #7579ed;
    border: 1px solid #dddfff;
    border-radius: 4px;
    width: 100%;
    margin-top: 1.5rem;
  }

  .donhin-btn--outline:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
  }

  .donhin-benefits {
    background: #fff;
    padding: 3.5rem 0;
  }

  .donhin-section-title {
    text-align: center;
    color: #15477f;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    margin: 0 0 2.5rem;
  }

  .donhin-section-title--light {
    color: #fff;
  }

  .donhin-benefits__grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .donhin-benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .donhin-benefits__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .donhin-benefit {
    text-align: center;
  }

  .donhin-benefit__icon {
    width: 5rem;
    height: 5rem;
    margin-inline: auto;
  }

  .donhin-benefit__title {
    margin: 1rem 0 0.5rem;
    color: #15477f;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .donhin-benefit__text {
    margin: 0;
    color: #333;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .donhin-form-section {
    background: #000;
    padding: 3rem 0 3.5rem;
  }

  .donhin-form-section__title {
    color: #fff;
    text-align: center;
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .donhin-form-section__inner {
    max-width: 36rem;
  }

  .donhin-form {
    background: #f5f5f5;
    border-radius: 0.5rem;
    padding: 1.5rem;
  }

  @media (min-width: 640px) {
    .donhin-form {
      padding: 2rem;
    }
  }

  .donhin-form__step--hidden {
    display: none;
  }

  .donhin-quiz {
    border: none;
    margin: 0;
    padding: 0;
  }

  .donhin-quiz__question {
    font-size: 1.125rem;
    font-weight: 700;
    color: #15477f;
    line-height: 1.4;
    margin-bottom: 1rem;
    padding: 0;
  }

  .donhin-quiz__options {
    display: grid;
    gap: 0.75rem;
  }

  .donhin-radio {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: #fff;
    border: 1px solid #e2e2e2;
    border-radius: 0.25rem;
    cursor: pointer;
    font-weight: 600;
    color: #15477f;
  }

  .donhin-radio input {
    width: 1.125rem;
    height: 1.125rem;
    accent-color: #5257de;
  }

  .donhin-form__heading {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: #15477f;
  }

  .donhin-fields {
    display: grid;
    gap: 0.75rem;
  }

  .donhin-field input {
    width: 100%;
    min-height: 48px;
    padding: 0.875rem 1rem;
    border: 1px solid #e2e2e2;
    border-radius: 0.25rem;
    font-size: 1rem;
    font-weight: 600;
    color: #15477f;
    background: #fff;
  }

  .donhin-field input:focus {
    outline: none;
    border-color: #5257de;
    box-shadow: 0 0 0 3px rgba(82, 87, 222, 0.25);
  }

  .donhin-privacy {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    margin-top: 1rem;
    font-size: 0.875rem;
    line-height: 1.45;
    color: #333;
    cursor: pointer;
  }

  .donhin-privacy input {
    margin-top: 0.2rem;
    accent-color: #5257de;
    flex-shrink: 0;
  }

  .donhin-privacy a {
    color: #5257de;
    text-decoration: underline;
  }

  .donhin-error,
  .donhin-status {
    margin: 0.75rem 0 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: #b91c1c;
  }

  .donhin-status {
    color: #15477f;
    text-align: center;
  }

  .hidden {
    display: none;
  }

  .donhin-cases {
    background: #15477f;
    padding: 3.5rem 0;
  }

  .donhin-cases__grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 900px) {
    .donhin-cases__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .donhin-case {
    background: #fff;
    border-radius: 0.5rem;
    overflow: hidden;
    padding-bottom: 1.25rem;
  }

  .donhin-case__badge {
    margin: 1rem 1rem 0;
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: #4caf50;
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: 0.25rem;
  }

  .donhin-case__img {
    width: 100%;
    height: auto;
    display: block;
    margin-top: 0.75rem;
  }

  .donhin-case__title {
    margin: 1rem 1.25rem 0.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: #15477f;
    line-height: 1.35;
  }

  .donhin-case__text {
    margin: 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: #333;
  }

  .donhin-about {
    background: #f5f5f5;
    padding: 3.5rem 0;
  }

  .donhin-about__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .donhin-about__grid {
      grid-template-columns: auto 1fr;
      gap: 2.5rem;
    }
  }

  .donhin-about__photo {
    width: min(100%, 17.5rem);
    height: auto;
    border-radius: 0.25rem;
    display: block;
    margin-inline: auto;
  }

  .donhin-about__title {
    margin: 0 0 1rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #15477f;
  }

  .donhin-about__list {
    margin: 0;
    padding-inline-start: 1.25rem;
    color: #15477f;
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 600;
  }

  .donhin-cta {
    background: #15477f;
    padding: 3rem 0;
    text-align: center;
  }

  .donhin-cta__title {
    margin: 0 0 1.5rem;
    color: #fff;
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 700;
  }
</style>
