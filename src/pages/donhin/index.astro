---
import LandingLayout from '../../layouts/LandingLayout.astro';

const benefits = [
  {
    icon: '/images/donhin/icon-consult.png',
    title: 'Бесплатная консультация',
    text: 'Оценка перспектив дела и помощь в сборе документов.',
  },
  {
    icon: '/images/donhin/icon-payment.png',
    title: 'Оплата по результатам — без риска',
    text: 'Платите только за результат, в котором вы уверены.',
  },
  {
    icon: '/images/donhin/icon-compensation.png',
    title: 'Максимальная компенсация',
    text: 'Компенсация, которая покроет все расходы и моральную компенсацию.',
  },
  {
    icon: '/images/donhin/icon-negotiation.png',
    title: 'Ведение переговоров',
    text: 'Переговоры с врачом, больницей и страховой компанией.',
  },
];

const cases = [
  {
    title: 'Компенсация в размере 115 000 шекелей за неудачное восстановление зубов',
    text: 'Женщина проходила стоматологическое лечение у двух врачей последовательно. Однако оба специалиста лишь ухудшили её состояние, и после многочисленных попыток восстановительное лечение полностью провалилось. В рамках судебного иска стороны пришли к соглашению, согласно которому женщина получит компенсацию в размере 115 000 шекелей.',
  },
  {
    title: 'Компенсация 233 тыс шекелей',
    text: 'Мужчина 50 лет обратился к врачу за стоматологическим протезированием. Изготовленные врачом съемные протезы не подошли пациенту. Врач предложил установить имплантаты и на них сделать постоянный протез. Врач имплантировал пациенту 12 имплантатов, но постоянный протез также не подошел. После многочисленных попыток исправить ситуацию, пациент подал в суд на врача. Суд вынес решение в пользу пациента и присудил ему компенсацию в размере 233 000 шекелей.',
  },
];
---

<LandingLayout
  title="Медицинская халатность в стоматологии | Адвокат Саймон Донхин"
  description="Получите положенную вам компенсацию за халатность стоматолога. Бесплатная консультация адвоката Саймона Донхина."
>
  <main id="main-content">
    <section class="donhin-hero">
      <div class="donhin-container donhin-hero__grid">
        <div class="donhin-hero__content">
          <p class="donhin-eyebrow">Медицинская халатность</p>
          <h1 class="donhin-hero__title">
            Получите положенную вам компенсацию за халатность стоматолога
          </h1>
          <p class="donhin-hero__subtitle">
            За последние 15 лет мои клиенты получили более 20 миллионов шекелей
          </p>
          <a href="#form-quiz" class="donhin-btn donhin-btn--hero">Запишитесь на бесплатную консультацию</a>
        </div>
        <div class="donhin-hero__photo-wrap">
          <img
            src="/images/donhin/hero.png"
            alt="Адвокат Саймон Донхин"
            class="donhin-hero__photo"
            width="397"
            height="397"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <p class="donhin-hero__name">
            <img
              src="/images/donhin/icon-scales.svg"
              alt=""
              width="47"
              height="33"
              class="donhin-hero__scales"
              loading="lazy"
              decoding="async"
            />
            <span>Адвокат Саймон Донхин</span>
          </p>
        </div>
      </div>
    </section>

    <section class="donhin-benefits">
      <div class="donhin-container">
        <h2 class="donhin-section-title">Почему стоит обратиться к адвокату Саймону?</h2>
        <div class="donhin-benefits__grid">
          {
            benefits.map((item) => (
              <article class="donhin-benefit">
                <div class="donhin-benefit__icon-wrap">
                  <img src={item.icon} alt="" width="150" height="150" class="donhin-benefit__icon" loading="lazy" decoding="async" />
                </div>
                <h3 class="donhin-benefit__title">{item.title}</h3>
                <p class="donhin-benefit__text">{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="form-quiz" class="donhin-form-section">
      <div class="donhin-container donhin-form-section__inner">
        <h2 class="donhin-form-section__title">Пройдите быстрый тест и узнайте свои шансы</h2>

        <form class="donhin-form donhin-form--quiz" id="donhin-quiz-form" data-donhin-form="quiz" novalidate>
          <div class="donhin-form__viewport">
          <div class="donhin-form__step is-active" data-step="1">
            <fieldset class="donhin-quiz">
              <legend class="donhin-quiz__question">
                Оказывалась ли вам медицинская или стоматологическая помощь в последние 7 лет?
              </legend>
              <div class="donhin-quiz__options">
                <label class="donhin-radio">
                  <input type="radio" name="quiz" value="да" required />
                  <span>Да</span>
                </label>
                <label class="donhin-radio">
                  <input type="radio" name="quiz" value="нет" />
                  <span>Нет</span>
                </label>
              </div>
            </fieldset>
            <button type="button" class="donhin-btn donhin-btn--quiz-action" data-quiz-next disabled>
              Следующий
            </button>
          </div>

          <div class="donhin-form__step" data-step="2" hidden>
            <button type="button" class="donhin-btn donhin-btn--quiz-back" data-quiz-back>
              ← Назад к вопросу
            </button>
            <h3 class="donhin-form__heading">Запишитесь на бесплатную консультацию</h3>
            <label class="donhin-field">
              <span class="sr-only">Имя</span>
              <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
            </label>
            <label class="donhin-field">
              <span class="sr-only">Телефон</span>
              <input
                type="tel"
                name="phone"
                placeholder="Номер телефона"
                required
                autocomplete="tel"
                inputmode="tel"
                pattern="[0-9\-+() ]{9,18}"
              />
            </label>
            <label class="donhin-privacy">
              <input type="checkbox" name="privacy" required />
              <span>
                Я ознакомлен(а) с{' '}
                <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
                {' '}и согласен(а) на обработку моих данных (обязательно)
              </span>
            </label>
            <p class="donhin-error hidden" data-privacy-error role="alert"></p>
            <button type="submit" class="donhin-btn donhin-btn--primary">Отправить</button>
          </div>
          </div>
          <p class="donhin-status hidden" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    <section class="donhin-cases">
      <div class="donhin-container">
        <h2 class="donhin-section-title">Примеры кейсов</h2>
        <div class="donhin-cases__grid">
          {
            cases.map((item) => (
              <article class="donhin-case">
                <h3 class="donhin-case__title">{item.title}</h3>
                <p class="donhin-case__text">{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="donhin-about">
      <div class="donhin-container donhin-about__grid">
        <img
          src="/images/donhin/about-photo.svg"
          alt="Адвокат Саймон Донхин"
          class="donhin-about__photo"
          width="240"
          height="349"
          loading="lazy"
          decoding="async"
        />
        <div class="donhin-about__content">
          <h2 class="donhin-about__title">Адвокат Саймон Донхин</h2>
          <ul class="donhin-about__list">
            <li>Опытный адвокат с более чем 15-летним стажем работы</li>
            <li>Первая степень по юриспруденции — Кирьят Оно</li>
            <li>Вторая степень по криминологии — Еврейский университет</li>
            <li>Специализация по медицинской халатности</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="form-bottom" class="donhin-bottom-form">
      <div class="donhin-container donhin-bottom-form__inner">
        <h2 class="donhin-bottom-form__title">Оставьте заявку для бесплатной консультации</h2>

        <form class="donhin-form donhin-form--bottom" id="donhin-bottom-form" data-donhin-form="simple" novalidate>
          <label class="donhin-field">
            <span class="sr-only">Имя</span>
            <input type="text" name="name" placeholder="Ваше имя" required autocomplete="name" />
          </label>
          <label class="donhin-field">
            <span class="sr-only">Телефон</span>
            <input
              type="tel"
              name="phone"
              placeholder="Номер телефона"
              required
              autocomplete="tel"
              inputmode="tel"
              pattern="[0-9\-+() ]{9,18}"
            />
          </label>
          <label class="donhin-privacy">
            <input type="checkbox" name="privacy" required />
            <span>
              Я ознакомлен(а) с{' '}
              <a href="/prat" target="_blank" rel="noopener noreferrer">политикой конфиденциальности</a>
              {' '}и согласен(а) на обработку моих данных (обязательно)
            </span>
          </label>
          <p class="donhin-error hidden" data-privacy-error role="alert"></p>
          <button type="submit" class="donhin-btn donhin-btn--brand donhin-btn--wide">Отправить</button>
          <p class="donhin-status hidden" data-status role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>
</LandingLayout>

<script>
  function readCookie(name: string) {
    const match = document.cookie.match(new RegExp(`(?:^|; )${name}=([^;]*)`));
    return match ? decodeURIComponent(match[1]) : '';
  }

  function collectTracking() {
    const url = new URL(window.location.href);
    const tracking: Record<string, string> = {};
    url.searchParams.forEach((value, key) => {
      tracking[key] = value;
    });
    const fbc = readCookie('_fbc');
    const fbp = readCookie('_fbp');
    if (fbc) tracking.fbc = fbc;
    if (fbp) tracking.fbp = fbp;
    return tracking;
  }

  function collectUtm() {
    const url = new URL(window.location.href);
    const keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'] as const;
    const utm: Record<string, string> = {};
    keys.forEach((key) => {
      const value = url.searchParams.get(key);
      if (value) utm[key] = value;
    });
    return utm;
  }

  async function submitDonhinLead(form: HTMLFormElement, formType: string) {
    const status = form.querySelector('[data-status]') as HTMLElement | null;
    const privacyError = form.querySelector('[data-privacy-error]') as HTMLElement | null;
    status?.classList.add('hidden');
    privacyError?.classList.add('hidden');

    const nameInput = form.querySelector('input[name="name"]') as HTMLInputElement | null;
    const phoneInput = form.querySelector('input[name="phone"]') as HTMLInputElement | null;
    const privacyInput = form.querySelector('input[name="privacy"]') as HTMLInputElement | null;
    const quizInput = form.querySelector('input[name="quiz"]:checked') as HTMLInputElement | null;
    const submitBtn = form.querySelector('[type="submit"]') as HTMLButtonElement | null;

    if (!privacyInput?.checked) {
      if (privacyError) {
        privacyError.textContent = 'Необходимо согласие с политикой конфиденциальности';
        privacyError.classList.remove('hidden');
      }
      return;
    }

    const name = nameInput?.value.trim() || '';
    const phone = phoneInput?.value.trim() || '';
    if (!name || name.length < 2 || !phone || !/^[0-9\-+() ]{9,18}$/.test(phone)) return;

    const originalLabel = submitBtn?.textContent || 'Отправить';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Отправка…';
    }

    let landingUrl = window.location.href;
    try {
      landingUrl = sessionStorage.getItem('pm_first_landing') || window.location.href;
    } catch {
      /* ignore */
    }

    const lang = [navigator.language, (navigator as Navigator & { userLanguage?: string }).userLanguage]
      .filter(Boolean)
      .join(' ');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          phone,
          client: 'donhin',
          formType,
          quizAnswer: quizInput?.value || '',
          pageUrl: window.location.href,
          landingUrl,
          referrer: document.referrer || '',
          utm: collectUtm(),
          tracking: { ...collectUtm(), ...collectTracking() },
          language: lang,
        }),
      });

      const data = (await res.json()) as { ok?: boolean };
      if (!res.ok || !data.ok) throw new Error('submit failed');

      window.location.href = '/donhin/thank-you';
    } catch {
      if (status) {
        status.textContent = 'Ошибка отправки. Попробуйте ещё раз.';
        status.classList.remove('hidden');
        status.setAttribute('role', 'alert');
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    }
  }

  const quizForm = document.getElementById('donhin-quiz-form') as HTMLFormElement | null;
  const bottomForm = document.getElementById('donhin-bottom-form') as HTMLFormElement | null;

  if (quizForm) {
    const step1 = quizForm.querySelector('[data-step="1"]') as HTMLElement | null;
    const step2 = quizForm.querySelector('[data-step="2"]') as HTMLElement | null;
    const nextBtn = quizForm.querySelector('[data-quiz-next]') as HTMLButtonElement | null;
    const backBtn = quizForm.querySelector('[data-quiz-back]') as HTMLButtonElement | null;
    const viewport = quizForm.querySelector('.donhin-form__viewport') as HTMLElement | null;

    const syncViewportHeight = () => {
      if (!viewport) return;
      const active = quizForm.querySelector('.donhin-form__step.is-active') as HTMLElement | null;
      if (active) viewport.style.minHeight = `${active.offsetHeight}px`;
    };

    const goToStep = (from: HTMLElement, to: HTMLElement, direction: 'forward' | 'back') => {
      const leaving = direction === 'forward' ? 'is-leaving-forward' : 'is-leaving-back';
      const entering = direction === 'forward' ? 'is-entering-forward' : 'is-entering-back';

      from.classList.remove('is-active');
      from.classList.add(leaving);

      window.setTimeout(() => {
        from.classList.remove(leaving);
        from.setAttribute('hidden', '');

        to.removeAttribute('hidden');
        to.classList.add(entering);
        requestAnimationFrame(() => {
          to.classList.remove(entering);
          to.classList.add('is-active');
          syncViewportHeight();
          if (direction === 'forward') {
            (quizForm.querySelector('input[name="name"]') as HTMLInputElement | null)?.focus();
          } else {
            (quizForm.querySelector('input[name="quiz"]:checked') as HTMLInputElement | null)?.focus();
          }
        });
      }, 280);
    };

    quizForm.querySelectorAll('input[name="quiz"]').forEach((input) => {
      input.addEventListener('change', () => {
        if (nextBtn) nextBtn.disabled = !quizForm.querySelector('input[name="quiz"]:checked');
      });
    });

    nextBtn?.addEventListener('click', () => {
      if (!quizForm.querySelector('input[name="quiz"]:checked') || !step1 || !step2) return;
      goToStep(step1, step2, 'forward');
    });

    backBtn?.addEventListener('click', () => {
      if (!step1 || !step2) return;
      goToStep(step2, step1, 'back');
    });

    syncViewportHeight();
    window.addEventListener('resize', syncViewportHeight);

    quizForm.addEventListener('submit', (e) => {
      e.preventDefault();
      submitDonhinLead(quizForm, 'quiz');
    });
  }

  bottomForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    submitDonhinLead(bottomForm, 'simple');
  });
</script>

<style>
  .donhin-container {
    width: min(100% - 2rem, 72rem);
    margin-inline: auto;
  }

  .donhin-eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .donhin-hero {
    background: #0c457f;
    color: #fff;
    padding: 2.75rem 0 3.25rem;
  }

  .donhin-hero__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (max-width: 899px) {
    .donhin-hero__content {
      text-align: center;
    }

    .donhin-hero__subtitle {
      margin-inline: auto;
    }

    .donhin-btn--hero {
      display: flex;
      width: 100%;
    }
  }

  @media (min-width: 900px) {
    .donhin-hero {
      padding: 4rem 0 4.5rem;
    }

    .donhin-hero__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 3rem;
    }
  }

  .donhin-hero__title {
    font-size: clamp(1.875rem, 4.2vw, 2.875rem);
    line-height: 1.12;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }

  .donhin-hero__subtitle {
    margin: 1.25rem 0 0;
    max-width: 34rem;
    font-size: clamp(1.0625rem, 2.2vw, 1.4375rem);
    line-height: 1.45;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
  }

  .donhin-hero__photo-wrap {
    text-align: center;
  }

  .donhin-hero__photo {
    width: min(100%, 24.8125rem);
    height: auto;
    display: block;
    margin-inline: auto;
  }

  .donhin-hero__name {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    margin: 1rem 0 0;
    font-size: 1.125rem;
    font-weight: 700;
  }

  .donhin-hero__scales {
    width: 2.75rem;
    height: auto;
    flex-shrink: 0;
  }

  .donhin-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .donhin-btn:hover {
    transform: translateY(-1px);
  }

  .donhin-btn:active {
    transform: translateY(0);
  }

  .donhin-btn:focus-visible {
    outline: 2px solid #7579ed;
    outline-offset: 3px;
  }

  .donhin-btn--hero {
    color: #fff;
    background: #111111;
    border: none;
    margin-top: 1.75rem;
    border-radius: 3.1875rem;
  }

  .donhin-btn--hero:hover {
    background: #000;
  }

  .donhin-btn--brand {
    background: #144379;
    color: #fff;
    margin-top: 1.25rem;
    border-radius: 1.875rem;
  }

  .donhin-btn--brand:hover {
    background: #15477f;
  }

  .donhin-btn--primary {
    background: #143c6f;
    color: #fff;
    width: 100%;
    margin-top: 1.25rem;
    border-radius: 0.25rem;
  }

  .donhin-btn--primary:hover {
    background: #123a66;
  }

  .donhin-btn--wide {
    width: 100%;
    margin-top: 1.25rem;
  }

  .donhin-btn--quiz-action {
    background: #143c6f;
    color: #fff;
    border-radius: 0.25rem;
    width: 100%;
    margin-top: 1.5rem;
  }

  .donhin-btn--quiz-action:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
  }

  .donhin-btn--quiz-action:not(:disabled):hover {
    background: #123a66;
  }

  .donhin-form-section {
    background: #fff;
    padding: 3.25rem 0 3.75rem;
  }

  .donhin-form-section__title {
    color: #15477f;
    text-align: center;
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .donhin-benefits {
    background: #eeeeee;
    padding: 3.75rem 0 4rem;
  }

  .donhin-section-title {
    text-align: center;
    color: #15477f;
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 700;
    margin: 0 0 2.75rem;
    text-wrap: balance;
  }

  .donhin-section-title--light {
    color: #fff;
  }

  .donhin-benefits__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .donhin-benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .donhin-benefits__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
  }

  .donhin-benefit {
    text-align: center;
    padding: 0 0.5rem 1rem;
    height: 100%;
  }

  .donhin-benefit__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 9.375rem;
    height: 9.375rem;
    margin-inline: auto;
  }

  .donhin-benefit__icon {
    width: 9.375rem;
    height: 9.375rem;
    object-fit: contain;
  }

  .donhin-benefit__title {
    margin: 1rem 0 0.625rem;
    color: #15477f;
    font-size: clamp(1.125rem, 2.2vw, 1.75rem);
    font-weight: 700;
    line-height: 1.3;
  }

  .donhin-benefit__text {
    margin: 0;
    color: #15477f;
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.5;
    max-width: 18rem;
    margin-inline: auto;
  }

  .donhin-form-section__inner,
  .donhin-bottom-form__inner {
    max-width: 36rem;
  }

  .donhin-form {
    background: #e6e6e6;
    border-radius: 0.75rem;
