---
import Layout from '../layouts/Layout.astro';
import '../styles/preview.css';
import PreviewBanner from '../components/preview/PreviewBanner.astro';
import PreviewHeader from '../components/preview/PreviewHeader.astro';
import PreviewHero from '../components/preview/PreviewHero.astro';
import PreviewJsonLd from '../components/preview/PreviewJsonLd.astro';
import AgencyStats from '../components/AgencyStats.astro';
import TargetAudience from '../components/TargetAudience.astro';
import PreviewCampaignResults from '../components/preview/PreviewCampaignResults.astro';
import Clients from '../components/Clients.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Services from '../components/Services.astro';
import VideoTestimonials from '../components/VideoTestimonials.astro';
import PreviewPortfolio from '../components/preview/PreviewPortfolio.astro';
import WhyUs from '../components/WhyUs.astro';
import PreviewFaq from '../components/preview/PreviewFaq.astro';
import PreviewContactForm from '../components/preview/PreviewContactForm.astro';
import LeadCaptureModal from '../components/preview/LeadCaptureModal.astro';
import StickyMobileCta from '../components/preview/StickyMobileCta.astro';
import Footer from '../components/Footer.astro';
import { previewSeo } from '../data/preview';
---

<Layout
  title={previewSeo.title}
  description={previewSeo.description}
  canonical={previewSeo.canonical}
  noindex={true}
  enableGtm={false}
>
  <PreviewJsonLd slot="head" />
  <div class="preview-page">
    <PreviewBanner />
    <PreviewHeader />
    <main id="main-content">
      <PreviewHero />
      <AgencyStats />
      <TargetAudience />
      <PreviewCampaignResults />
      <Clients />
      <HowItWorks />
      <Services />
      <VideoTestimonials />
      <PreviewPortfolio />
      <WhyUs />
      <PreviewFaq />
      <PreviewContactForm />
    </main>
    <Footer />
    <LeadCaptureModal />
    <StickyMobileCta />
  </div>
</Layout>
